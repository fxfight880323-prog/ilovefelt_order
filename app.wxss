/* ============================================
   Sùyǎ Artisans Design System
   The Tactile Editorial - WeChat Mini Program
   ============================================ */

/* ------------------------------------------
   1. Design Tokens - Colors
   ------------------------------------------ */
page {
  /* Primary - Deep Clay */
  --primary: #6c5842;
  --primary-container: #867159;
  --on-primary: #ffffff;
  --on-primary-container: #fffbff;
  --primary-fixed: #fadec1;
  --primary-fixed-dim: #dcc2a7;
  --inverse-primary: #dcc2a7;
  
  /* Secondary - Warm Stone */
  --secondary: #5f5e5c;
  --secondary-container: #e5e2df;
  --on-secondary: #ffffff;
  --on-secondary-container: #656462;
  --secondary-fixed: #e5e2df;
  --secondary-fixed-dim: #c9c6c3;
  
  /* Tertiary - Organic */
  --tertiary: #655a4b;
  --tertiary-container: #7f7362;
  --tertiary-fixed: #f0e0cc;
  --tertiary-fixed-dim: #d3c4b1;
  --on-tertiary: #ffffff;
  --on-tertiary-fixed: #221a0e;
  --on-tertiary-fixed-variant: #4f4537;
  
  /* Surface - Linen Canvas */
  --surface: #fcf9f4;
  --surface-bright: #fcf9f4;
  --surface-dim: #dcdad5;
  --surface-variant: #e5e2dd;
  
  /* Surface Containers - Tonal Layering */
  --surface-container-lowest: #ffffff;
  --surface-container-low: #f6f3ee;
  --surface-container: #f0ede8;
  --surface-container-high: #ebe8e3;
  --surface-container-highest: #e5e2dd;
  
  /* Text Colors */
  --on-surface: #1c1c19;
  --on-surface-variant: #4e453d;
  --inverse-surface: #31302d;
  --inverse-on-surface: #f3f0eb;
  
  /* Outline - Ghost Borders */
  --outline: #7f756c;
  --outline-variant: #d1c4ba;
  
  /* Error */
  --error: #ba1a1a;
  --error-container: #ffdad6;
  --on-error: #ffffff;
  --on-error-container: #93000a;
  
  /* Background */
  --background: #fcf9f4;
  --on-background: #1c1c19;
  
  /* Surface Tint */
  --surface-tint: #6f5b44;

  /* ------------------------------------------
     2. Spacing Scale
     ------------------------------------------ */
  --space-1: 4rpx;
  --space-2: 8rpx;
  --space-3: 12rpx;
  --space-4: 16rpx;
  --space-5: 20rpx;
  --space-6: 24rpx;
  --space-8: 32rpx;
  --space-10: 40rpx;
  --space-12: 48rpx;
  --space-16: 64rpx;
  --space-20: 80rpx;

  /* ------------------------------------------
     3. Border Radius
     ------------------------------------------ */
  --radius-sm: 8rpx;
  --radius-md: 12rpx;
  --radius-lg: 16rpx;
  --radius-xl: 24rpx;
  --radius-2xl: 32rpx;
  --radius-full: 9999rpx;

  /* ------------------------------------------
     4. Shadows - Ambient & Atmospheric
     ------------------------------------------ */
  --shadow-sm: 0 2rpx 8rpx rgba(28, 28, 25, 0.04);
  --shadow-md: 0 4rpx 16rpx rgba(28, 28, 25, 0.06);
  --shadow-lg: 0 10rpx 30rpx rgba(28, 28, 25, 0.05);
  --shadow-float: 0 20rpx 60rpx rgba(28, 28, 25, 0.08);
  --shadow-nav: 0 -5rpx 20rpx rgba(28, 28, 25, 0.03);

  /* ------------------------------------------
     5. Typography Scale
     ------------------------------------------ */
  /* Display */
  --display-lg: 72rpx;
  --display-md: 56rpx;
  --display-sm: 48rpx;
  
  /* Headlines */
  --headline-lg: 44rpx;
  --headline-md: 36rpx;
  --headline-sm: 32rpx;
  
  /* Titles */
  --title-lg: 32rpx;
  --title-md: 28rpx;
  --title-sm: 26rpx;
  
  /* Body */
  --body-lg: 30rpx;
  --body-md: 28rpx;
  --body-sm: 26rpx;
  --body-xs: 22rpx;
  
  /* Labels */
  --label-lg: 26rpx;
  --label-md: 24rpx;
  --label-sm: 22rpx;
  --label-xs: 20rpx;

  /* Line Heights */
  --leading-tight: 1.2;
  --leading-normal: 1.5;
  --leading-relaxed: 1.6;

  /* Letter Spacing */
  --tracking-tight: -0.02em;
  --tracking-normal: 0;
  --tracking-wide: 0.05em;
  --tracking-wider: 0.1em;

  /* Font Weights */
  --font-normal: 400;
  --font-medium: 500;
  --font-semibold: 600;
  --font-bold: 700;
  --font-extrabold: 800;

  /* ------------------------------------------
     6. Animation
     ------------------------------------------ */
  --ease-out: cubic-bezier(0.0, 0.0, 0.2, 1);
  --ease-in-out: cubic-bezier(0.4, 0.0, 0.2, 1);
  --duration-fast: 200ms;
  --duration-normal: 300ms;
  --duration-slow: 500ms;
}

/* ------------------------------------------
   7. Base Styles
   ------------------------------------------ */
page {
  background-color: var(--surface);
  color: var(--on-surface);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  line-height: var(--leading-normal);
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

/* ------------------------------------------
   8. Container & Layout
   ------------------------------------------ */
.container {
  padding: var(--space-5);
  padding-bottom: calc(var(--space-5) + 120rpx);
  min-height: 100vh;
  background-color: var(--surface);
}

.canvas-bg {
  background-color: var(--surface);
  position: relative;
}

/* Material Grain Texture Overlay */
.canvas-bg::before {
  content: "";
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-image: radial-gradient(var(--outline-variant) 0.5rpx, transparent 0.5rpx);
  background-size: 16rpx 16rpx;
  opacity: 0.3;
  pointer-events: none;
  z-index: 0;
}

/* ------------------------------------------
   9. Cards - The "No Border" Rule
   ------------------------------------------ */
.card {
  background: var(--surface-container-low);
  border-radius: var(--radius-xl);
  padding: var(--space-6);
  margin-bottom: var(--space-5);
  position: relative;
  z-index: 1;
}

.card-elevated {
  background: var(--surface-container-lowest);
  box-shadow: var(--shadow-md);
}

.card-filled {
  background: var(--surface-container);
}

.card-primary {
  background: var(--primary);
  color: var(--on-primary);
}

.card-secondary {
  background: var(--secondary-fixed);
}

/* Card Title */
.card-title {
  font-size: var(--title-lg);
  font-weight: var(--font-bold);
  color: var(--on-surface);
  margin-bottom: var(--space-4);
  letter-spacing: var(--tracking-tight);
}

.card-subtitle {
  font-size: var(--body-sm);
  color: var(--on-surface-variant);
  margin-top: calc(var(--space-1) * -1);
  margin-bottom: var(--space-4);
}

/* ------------------------------------------
   10. Typography Classes
   ------------------------------------------ */
.display-lg {
  font-size: var(--display-lg);
  font-weight: var(--font-extrabold);
  letter-spacing: var(--tracking-tight);
  line-height: var(--leading-tight);
}

.display-md {
  font-size: var(--display-md);
  font-weight: var(--font-extrabold);
  letter-spacing: var(--tracking-tight);
  line-height: var(--leading-tight);
}

.headline-lg {
  font-size: var(--headline-lg);
  font-weight: var(--font-bold);
  letter-spacing: var(--tracking-tight);
  line-height: var(--leading-tight);
}

.headline-md {
  font-size: var(--headline-md);
  font-weight: var(--font-bold);
  letter-spacing: var(--tracking-tight);
  line-height: var(--leading-tight);
}

.headline-sm {
  font-size: var(--headline-sm);
  font-weight: var(--font-bold);
  letter-spacing: var(--tracking-tight);
  line-height: var(--leading-tight);
}

.title-lg {
  font-size: var(--title-lg);
  font-weight: var(--font-semibold);
}

.title-md {
  font-size: var(--title-md);
  font-weight: var(--font-semibold);
}

.title-sm {
  font-size: var(--title-sm);
  font-weight: var(--font-semibold);
}

.body-lg {
  font-size: var(--body-lg);
  line-height: var(--leading-relaxed);
}

.body-md {
  font-size: var(--body-md);
  line-height: var(--leading-relaxed);
}

.body-sm {
  font-size: var(--body-sm);
  line-height: var(--leading-normal);
}

.label-lg {
  font-size: var(--label-lg);
  font-weight: var(--font-medium);
  letter-spacing: var(--tracking-wide);
  text-transform: uppercase;
}

.label-md {
  font-size: var(--label-md);
  font-weight: var(--font-medium);
  letter-spacing: var(--tracking-wide);
  text-transform: uppercase;
}

.label-sm {
  font-size: var(--label-sm);
  font-weight: var(--font-medium);
  letter-spacing: var(--tracking-wider);
  text-transform: uppercase;
}

/* Text Colors */
.text-primary { color: var(--primary); }
.text-secondary { color: var(--secondary); }
.text-tertiary { color: var(--tertiary); }
.text-on-surface { color: var(--on-surface); }
.text-on-surface-variant { color: var(--on-surface-variant); }
.text-outline { color: var(--outline); }
.text-error { color: var(--error); }

/* Text Styles */
.text-muted { opacity: 0.6; }
.text-italic { font-style: italic; }
.text-center { text-align: center; }
.text-right { text-align: right; }

/* ------------------------------------------
   11. Buttons
   ------------------------------------------ */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: var(--space-3) var(--space-6);
  border-radius: var(--radius-md);
  font-size: var(--body-md);
  font-weight: var(--font-medium);
  transition: all var(--duration-normal) var(--ease-out);
  border: none;
}

.btn::after {
  border: none;
}

/* Primary Button - Solid Clay */
.btn-primary {
  background: var(--primary);
  color: var(--on-primary);
  box-shadow: var(--shadow-sm);
}

.btn-primary:active {
  background: var(--primary-container);
  transform: translateY(2rpx);
}

/* Secondary Button - Stone Container */
.btn-secondary {
  background: var(--secondary-container);
  color: var(--on-secondary-container);
}

.btn-secondary:active {
  background: var(--secondary-fixed-dim);
}

/* Tertiary Button - Text Only */
.btn-tertiary {
  background: transparent;
  color: var(--primary);
  text-decoration: underline;
  text-decoration-color: var(--outline-variant);
  text-underline-offset: 8rpx;
}

/* Outline Button - Ghost Border */
.btn-outline {
  background: transparent;
  color: var(--primary);
  box-shadow: inset 0 0 0 2rpx var(--outline-variant);
}

.btn-outline:active {
  background: var(--surface-container);
}

/* Button Sizes */
.btn-sm {
  padding: var(--space-2) var(--space-4);
  font-size: var(--body-sm);
}

.btn-lg {
  padding: var(--space-4) var(--space-8);
  font-size: var(--body-lg);
}

.btn-full {
  width: 100%;
}

/* ------------------------------------------
   12. Chips & Tags - Organic Shapes
   ------------------------------------------ */
.chip {
  display: inline-flex;
  align-items: center;
  padding: var(--space-2) var(--space-4);
  border-radius: var(--radius-full);
  font-size: var(--label-md);
  font-weight: var(--font-medium);
}

.chip-primary {
  background: var(--tertiary-fixed);
  color: var(--on-tertiary-fixed);
}

.chip-secondary {
  background: var(--secondary-fixed);
  color: var(--on-secondary-fixed);
}

.chip-outline {
  background: transparent;
  box-shadow: inset 0 0 0 2rpx var(--outline-variant);
  color: var(--on-surface-variant);
}

.tag {
  display: inline-flex;
  align-items: center;
  padding: var(--space-1) var(--space-3);
  border-radius: var(--radius-sm);
  font-size: var(--label-sm);
  font-weight: var(--font-medium);
}

/* Status Tags */
.status-pending { 
  background: var(--tertiary-fixed); 
  color: var(--on-tertiary-fixed); 
}
.status-active { 
  background: var(--primary-fixed); 
  color: var(--on-primary-fixed); 
}
.status-success { 
  background: #e6f7e6;
  color: #52c41a;
}
.status-error { 
  background: var(--error-container);
  color: var(--error);
}

/* ------------------------------------------
   13. Input Fields - Bottom Border Style
   ------------------------------------------ */
.input-field {
  position: relative;
  margin-bottom: var(--space-5);
}

.input-label {
  display: block;
  font-size: var(--label-md);
  color: var(--on-surface-variant);
  margin-bottom: var(--space-2);
  letter-spacing: var(--tracking-wide);
  text-transform: uppercase;
}

.input {
  width: 100%;
  padding: var(--space-3) 0;
  font-size: var(--body-md);
  color: var(--on-surface);
  background: transparent;
  border: none;
  border-bottom: 2rpx solid var(--outline-variant);
  border-radius: 0;
  transition: border-color var(--duration-normal);
}

.input:focus {
  border-bottom-color: var(--primary);
}

.input::placeholder {
  color: var(--outline);
}

/* ------------------------------------------
   14. Lists - No Divider Lines
   ------------------------------------------ */
.list {
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
}

.list-item {
  padding: var(--space-4);
  background: var(--surface-container-lowest);
  border-radius: var(--radius-lg);
  transition: background var(--duration-fast);
}

.list-item:active {
  background: var(--surface-container);
}

/* ------------------------------------------
   15. Menu Items
   ------------------------------------------ */
.menu-item {
  display: flex;
  align-items: center;
  padding: var(--space-4);
  border-radius: var(--radius-lg);
  transition: background var(--duration-fast);
}

.menu-item:active {
  background: var(--surface-container-highest);
}

.menu-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--radius-full);
  background: var(--surface-container-highest);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: var(--space-4);
  font-size: 36rpx;
  color: var(--primary);
  transition: all var(--duration-fast);
}

.menu-item:active .menu-icon {
  background: var(--primary);
  color: var(--on-primary);
}

.menu-content {
  flex: 1;
}

.menu-title {
  font-size: var(--title-sm);
  font-weight: var(--font-semibold);
  color: var(--on-surface);
  margin-bottom: var(--space-1);
}

.menu-desc {
  font-size: var(--body-xs);
  color: var(--on-surface-variant);
}

.menu-arrow {
  font-size: var(--title-lg);
  color: var(--outline-variant);
}

/* ------------------------------------------
   16. Empty State
   ------------------------------------------ */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--space-16) var(--space-6);
  text-align: center;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: var(--space-5);
  opacity: 0.6;
}

.empty-text {
  font-size: var(--title-md);
  font-weight: var(--font-semibold);
  color: var(--on-surface);
  margin-bottom: var(--space-2);
}

.empty-desc {
  font-size: var(--body-sm);
  color: var(--on-surface-variant);
}

/* ------------------------------------------
   17. Grid Layouts - Bento Style
   ------------------------------------------ */
.grid-2 {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--space-4);
}

.grid-3 {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-4);
}

.grid-4 {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: var(--space-3);
}

/* Bento Grid Variations */
.bento-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--space-4);
}

.bento-item-full {
  grid-column: span 2;
}

/* ------------------------------------------
   18. Utility Classes
   ------------------------------------------ */
.flex { display: flex; }
.flex-col { flex-direction: column; }
.items-center { align-items: center; }
.justify-center { justify-content: center; }
.justify-between { justify-content: space-between; }
.flex-1 { flex: 1; }

.gap-1 { gap: var(--space-1); }
.gap-2 { gap: var(--space-2); }
.gap-3 { gap: var(--space-3); }
.gap-4 { gap: var(--space-4); }

.mt-1 { margin-top: var(--space-1); }
.mt-2 { margin-top: var(--space-2); }
.mt-3 { margin-top: var(--space-3); }
.mt-4 { margin-top: var(--space-4); }
.mt-6 { margin-top: var(--space-6); }

.mb-1 { margin-bottom: var(--space-1); }
.mb-2 { margin-bottom: var(--space-2); }
.mb-3 { margin-bottom: var(--space-3); }
.mb-4 { margin-bottom: var(--space-4); }
.mb-6 { margin-bottom: var(--space-6); }

.ml-2 { margin-left: var(--space-2); }
.ml-3 { margin-left: var(--space-3); }
.ml-4 { margin-left: var(--space-4); }

.mr-2 { margin-right: var(--space-2); }
.mr-3 { margin-right: var(--space-3); }
.mr-4 { margin-right: var(--space-4); }

.p-4 { padding: var(--space-4); }
.p-6 { padding: var(--space-6); }

.rounded-lg { border-radius: var(--radius-lg); }
.rounded-xl { border-radius: var(--radius-xl); }
.rounded-full { border-radius: var(--radius-full); }

.relative { position: relative; }
.absolute { position: absolute; }
.overflow-hidden { overflow: hidden; }

.w-full { width: 100%; }
.h-full { height: 100%; }

/* Aspect Ratios */
.aspect-square { aspect-ratio: 1; }
.aspect-video { aspect-ratio: 16 / 9; }

/* ------------------------------------------
   19. Avatar Styles
   ------------------------------------------ */
.avatar {
  border-radius: var(--radius-full);
  overflow: hidden;
  border: 4rpx solid var(--surface-container-highest);
}

.avatar-sm { width: 64rpx; height: 64rpx; }
.avatar-md { width: 96rpx; height: 96rpx; }
.avatar-lg { width: 144rpx; height: 144rpx; }
.avatar-xl { width: 200rpx; height: 200rpx; }

/* Avatar with badge */
.avatar-wrap {
  position: relative;
  display: inline-block;
}

.avatar-badge {
  position: absolute;
  bottom: -4rpx;
  right: -4rpx;
  width: 36rpx;
  height: 36rpx;
  background: var(--primary);
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  color: var(--on-primary);
  border: 4rpx solid var(--surface);
}

/* ------------------------------------------
   20. Navigation Bar
   ------------------------------------------ */
.nav-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(252, 249, 244, 0.9);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-top: 2rpx solid rgba(209, 196, 186, 0.2);
  box-shadow: var(--shadow-nav);
  z-index: 100;
  padding-bottom: env(safe-area-inset-bottom);
}

.nav-items {
  display: flex;
  justify-content: space-around;
  align-items: center;
  height: 100rpx;
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--space-2) var(--space-4);
  color: var(--on-surface-variant);
  opacity: 0.6;
  transition: all var(--duration-normal);
}

.nav-item.active {
  opacity: 1;
  color: var(--primary);
  background: var(--surface-container);
  border-radius: var(--radius-lg);
}

.nav-icon {
  font-size: 40rpx;
  margin-bottom: 4rpx;
}

.nav-label {
  font-size: 20rpx;
  font-weight: var(--font-medium);
}

/* ------------------------------------------
   21. Divider - Ghost Border
   ------------------------------------------ */
.divider {
  height: 2rpx;
  background: var(--outline-variant);
  opacity: 0.15;
  margin: var(--space-4) 0;
}

/* ------------------------------------------
   22. Hero Section - Material Header
   ------------------------------------------ */
.hero-section {
  padding: var(--space-8) var(--space-6);
  background: linear-gradient(180deg, var(--surface-variant) 0%, var(--surface) 100%);
  position: relative;
}

.hero-section::before {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 200rpx;
  background: var(--surface-variant);
  opacity: 0.5;
}

.hero-title {
  font-size: var(--display-sm);
  font-weight: var(--font-extrabold);
  color: var(--primary);
  letter-spacing: var(--tracking-tight);
  line-height: var(--leading-tight);
  position: relative;
}

.hero-subtitle {
  font-size: var(--body-lg);
  color: var(--on-surface-variant);
  margin-top: var(--space-3);
  line-height: var(--leading-relaxed);
  position: relative;
}

/* ------------------------------------------
   23. Section Header
   ------------------------------------------ */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: var(--space-5);
  padding-left: var(--space-2);
}

.section-title {
  font-size: var(--headline-sm);
  font-weight: var(--font-bold);
  color: var(--on-surface);
  letter-spacing: var(--tracking-tight);
}

.section-action {
  font-size: var(--body-sm);
  color: var(--primary);
  font-weight: var(--font-medium);
}

/* ------------------------------------------
   24. Stats Display
   ------------------------------------------ */
.stat-value {
  font-size: var(--display-sm);
  font-weight: var(--font-extrabold);
  color: var(--primary);
  letter-spacing: var(--tracking-tight);
}

.stat-label {
  font-size: var(--label-sm);
  color: var(--on-surface-variant);
  letter-spacing: var(--tracking-wider);
  text-transform: uppercase;
  margin-top: var(--space-1);
}

/* ------------------------------------------
   25. Image Gallery - Asymmetric
   ------------------------------------------ */
.gallery-asymmetric {
  display: flex;
  gap: var(--space-4);
}

.gallery-main {
  flex: 3;
  border-radius: var(--radius-xl);
  overflow: hidden;
}

.gallery-side {
  flex: 2;
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
}

.gallery-item {
  border-radius: var(--radius-xl);
  overflow: hidden;
  position: relative;
}

.gallery-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: var(--space-4);
  background: linear-gradient(transparent, rgba(28, 28, 25, 0.6));
  color: var(--surface);
}

/* ------------------------------------------
   26. Feedback/Journal Entry
   ------------------------------------------ */
.journal-entry {
  position: relative;
  padding-left: var(--space-6);
  border-left: 2rpx solid var(--outline-variant);
  margin-bottom: var(--space-6);
}

.journal-dot {
  position: absolute;
  left: -10rpx;
  top: 8rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: var(--radius-full);
  background: var(--primary);
}

.journal-author {
  font-size: var(--label-sm);
  font-weight: var(--font-semibold);
  color: var(--primary);
  letter-spacing: var(--tracking-wide);
  text-transform: uppercase;
  margin-bottom: var(--space-1);
}

.journal-content {
  font-size: var(--body-sm);
  color: var(--on-surface-variant);
  font-style: italic;
  line-height: var(--leading-relaxed);
  margin-bottom: var(--space-2);
}

.journal-meta {
  font-size: var(--label-xs);
  color: var(--outline);
  letter-spacing: var(--tracking-wider);
  text-transform: uppercase;
}

/* ------------------------------------------
   27. Bottom Sheet / Modal
   ------------------------------------------ */
.sheet {
  background: var(--surface-container-low);
  border-radius: var(--radius-2xl) var(--radius-2xl) 0 0;
  padding: var(--space-6);
  box-shadow: var(--shadow-float);
}

.sheet-handle {
  width: 72rpx;
  height: 6rpx;
  background: var(--outline-variant);
  border-radius: var(--radius-full);
  margin: 0 auto var(--space-6);
}

/* ------------------------------------------
   28. Loading & Skeleton
   ------------------------------------------ */
.skeleton {
  background: linear-gradient(
    90deg,
    var(--surface-container) 0%,
    var(--surface-container-high) 50%,
    var(--surface-container) 100%
  );
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: var(--radius-md);
}

@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* ------------------------------------------
   29. Safe Area
   ------------------------------------------ */
.safe-bottom {
  padding-bottom: calc(var(--space-5) + env(safe-area-inset-bottom));
}

/* ------------------------------------------
   30. Animation Utilities
   ------------------------------------------ */
.fade-in {
  animation: fadeIn var(--duration-normal) var(--ease-out);
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.scale-in {
  animation: scaleIn var(--duration-normal) var(--ease-out);
}

@keyframes scaleIn {
  from { transform: scale(0.95); opacity: 0; }
  to { transform: scale(1); opacity: 1; }
}

/* Slide up animation for cards */
.slide-up {
  animation: slideUp var(--duration-slow) var(--ease-out);
}

@keyframes slideUp {
  from { transform: translateY(40rpx); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}
