/* 用户卡片 */
.user-card {
  background: linear-gradient(135deg, #1890ff 0%, #36cfc9 100%);
  color: #ffffff;
}

.user-info {
  flex: 1;
}

.user-name {
  font-size: 40rpx;
  font-weight: 600;
  margin-bottom: 10rpx;
}

.user-role {
  display: flex;
  align-items: center;
}

.user-role .tag {
  background: rgba(255, 255, 255, 0.2);
  color: #ffffff;
}

.user-role .star {
  color: rgba(255, 255, 255, 0.4);
}

.user-role .star.active {
  color: #ffd700;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

/* 统计 */
.stats-grid {
  margin-bottom: 20rpx;
}

.stat-item {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx 20rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.stat-number {
  font-size: 48rpx;
  font-weight: 700;
  margin-bottom: 10rpx;
  color: var(--text-color);
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-color-secondary);
}

/* 菜单 */
.menu-grid {
  margin-top: 20rpx;
}

.menu-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  border-radius: 12rpx;
  transition: background 0.3s;
}

.menu-item:active {
  background: var(--bg-color);
}

.menu-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-bottom: 16rpx;
}

.icon-order { background: rgba(24, 144, 255, 0.1); }
.icon-manage { background: rgba(82, 196, 26, 0.1); }
.icon-style { background: rgba(250, 173, 20, 0.1); }
.icon-craftsman { background: rgba(245, 34, 45, 0.1); }
.icon-hall { background: rgba(24, 144, 255, 0.1); }
.icon-my { background: rgba(82, 196, 26, 0.1); }
.icon-profile { background: rgba(250, 173, 20, 0.1); }

.menu-text {
  font-size: 26rpx;
  color: var(--text-color);
}

/* 公告 */
.notice-list {
  margin-top: 10rpx;
}

.notice-item {
  display: flex;
  align-items: flex-start;
  padding: 20rpx 0;
  border-bottom: 2rpx solid var(--border-color);
}

.notice-item:last-child {
  border-bottom: none;
}

.notice-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: var(--primary-color);
  margin-right: 20rpx;
  margin-top: 10rpx;
  flex-shrink: 0;
}

.notice-content {
  flex: 1;
}

.notice-title {
  font-size: 28rpx;
  color: var(--text-color);
  margin-bottom: 8rpx;
  line-height: 1.5;
}

.notice-time {
  color: var(--text-color-light);
}

/* 空状态 */
.empty-desc {
  color: var(--text-color-light);
  font-size: 26rpx;
  margin-top: 10rpx;
}
