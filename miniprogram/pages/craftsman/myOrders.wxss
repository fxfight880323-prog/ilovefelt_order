/* 状态标签页 */
.status-tabs {
  display: flex;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 10rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 10rpx;
  font-size: 28rpx;
  color: var(--text-color-secondary);
  border-radius: 12rpx;
  transition: all 0.3s;
}

.tab-item.active {
  background: var(--primary-color);
  color: #ffffff;
}

/* 订单卡片 */
.order-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid var(--border-color);
}

.order-name {
  font-size: 32rpx;
  font-weight: 600;
  flex: 1;
  margin-right: 20rpx;
}

.order-body {
  margin-bottom: 20rpx;
}

.order-footer {
  display: flex;
  justify-content: flex-end;
  padding-top: 20rpx;
  border-top: 2rpx solid var(--border-color);
}
