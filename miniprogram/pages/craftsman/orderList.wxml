<view class="container">
  <!-- 提示栏 -->
  <view class="notice-bar" bindtap="requestSubscribe">
    <text class="notice-icon">🔔</text>
    <text class="notice-text">点击开启新订单消息提醒</text>
    <text class="notice-btn">去开启</text>
  </view>

  <!-- 订单列表 -->
  <view class="order-list">
    <view class="list-item order-card" wx:for="{{orderList}}" wx:key="_id">
      <view class="order-header">
        <view class="order-name">{{item.name}}</view>
        <view class="status-tag status-pending">待接单</view>
      </view>
      
      <view class="order-body" bindtap="viewDetail" data-id="{{item._id}}">
        <view class="info-row">
          <text class="info-label">样式：</text>
          <text class="info-value">{{item.styleName}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">数量：</text>
          <text class="info-value">{{item.quantity}} 件</text>
        </view>
        <view class="info-row">
          <text class="info-label">单价：</text>
          <text class="info-value text-primary">¥{{item.price}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">总价：</text>
          <text class="info-value text-error text-bold">¥{{item.totalPrice}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">收货日期：</text>
          <text class="info-value">{{item.receiveDate}}</text>
        </view>
        <view class="info-row" wx:if="{{item.remark}}">
          <text class="info-label">备注：</text>
          <text class="info-value">{{item.remark}}</text>
        </view>
      </view>
      
      <view class="order-footer">
        <text class="publish-time">发布于 {{item.createTime}}</text>
        <view class="btn btn-primary btn-sm" bindtap="takeOrder" data-id="{{item._id}}">立即接单</view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!loading && orderList.length === 0}}">
    <view class="empty-icon">📭</view>
    <view class="empty-text">暂无可接订单</view>
    <view class="empty-desc">开启消息提醒，新订单及时通知您</view>
  </view>

  <!-- 加载更多 -->
  <view class="load-more" wx:if="{{hasMore}}">
    {{loading ? '加载中...' : '上拉加载更多'}}
  </view>
</view>
