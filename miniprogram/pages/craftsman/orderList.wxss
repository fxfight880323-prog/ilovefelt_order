/* 提示栏 */
.notice-bar {
  display: flex;
  align-items: center;
  background: rgba(24, 144, 255, 0.1);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 20rpx;
}

.notice-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.notice-text {
  flex: 1;
  font-size: 26rpx;
  color: var(--primary-color);
}

.notice-btn {
  font-size: 26rpx;
  color: var(--primary-color);
  font-weight: 500;
  padding: 8rpx 20rpx;
  background: rgba(24, 144, 255, 0.1);
  border-radius: 8rpx;
}

/* 订单卡片 */
.order-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid var(--border-color);
}

.order-name {
  font-size: 32rpx;
  font-weight: 600;
  flex: 1;
  margin-right: 20rpx;
}

.order-body {
  margin-bottom: 20rpx;
}

.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20rpx;
  border-top: 2rpx solid var(--border-color);
}

.publish-time {
  font-size: 24rpx;
  color: var(--text-color-light);
}
