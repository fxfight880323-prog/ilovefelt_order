<view class="container">
  <!-- 未注册提示 -->
  <view class="card" wx:if="{{!craftsmanInfo}}">
    <view class="empty-state">
      <view class="empty-icon">📝</view>
      <view class="empty-text">您还未注册成为手工艺人</view>
      <view class="empty-desc">请联系管理员进行注册</view>
    </view>
  </view>

  <block wx:if="{{craftsmanInfo}}">
    <!-- 状态筛选 -->
    <view class="status-tabs">
      <view 
        class="tab-item {{currentStatus === item.value ? 'active' : ''}}"
        wx:for="{{statusOptions}}"
        wx:key="value"
        data-status="{{item.value}}"
        bindtap="switchStatus"
      >
        {{item.label}}
      </view>
    </view>

    <!-- 订单列表 -->
    <view class="order-list">
      <view class="list-item order-card" wx:for="{{orderList}}" wx:key="_id">
        <view class="order-header" bindtap="viewDetail" data-id="{{item._id}}">
          <view class="order-name">{{item.name}}</view>
          <view class="status-tag status-{{item.status}}">
            {{item.status === 'accepted' ? '进行中' : '已完成'}}
          </view>
        </view>
        
        <view class="order-body" bindtap="viewDetail" data-id="{{item._id}}">
          <view class="info-row">
            <text class="info-label">样式：</text>
            <text class="info-value">{{item.styleName}}</text>
          </view>
          <view class="info-row">
            <text class="info-label">数量：</text>
            <text class="info-value">{{item.quantity}} 件</text>
          </view>
          <view class="info-row">
            <text class="info-label">总价：</text>
            <text class="info-value text-error text-bold">¥{{item.totalPrice}}</text>
          </view>
          <view class="info-row">
            <text class="info-label">收货日期：</text>
            <text class="info-value">{{item.receiveDate}}</text>
          </view>
          <view class="info-row">
            <text class="info-label">接单时间：</text>
            <text class="info-value">{{item.acceptDate}}</text>
          </view>
        </view>
        
        <view class="order-footer" wx:if="{{item.status === 'accepted'}}">
          <view class="btn btn-success btn-sm" bindtap="completeOrder" data-id="{{item._id}}">完成订单</view>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{!loading && orderList.length === 0}}">
      <view class="empty-icon">📭</view>
      <view class="empty-text">暂无订单</view>
      <view class="empty-desc">快去接单大厅看看吧</view>
    </view>

    <!-- 加载更多 -->
    <view class="load-more" wx:if="{{hasMore}}">
      {{loading ? '加载中...' : '上拉加载更多'}}
    </view>
  </block>
</view>
