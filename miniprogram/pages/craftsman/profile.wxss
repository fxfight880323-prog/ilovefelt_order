/* 用户卡片 */
.user-card {
  background: linear-gradient(135deg, #1890ff 0%, #36cfc9 100%);
  color: #ffffff;
}

.user-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.user-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  margin-right: 30rpx;
}

.user-info {
  flex: 1;
}

.user-name {
  font-size: 40rpx;
  font-weight: 600;
  margin-bottom: 10rpx;
}

.user-stars {
  margin-bottom: 10rpx;
}

.user-stars .star {
  color: rgba(255, 255, 255, 0.4);
  font-size: 28rpx;
  margin-right: 4rpx;
}

.user-stars .star.active {
  color: #ffd700;
}

.user-specialty .tag {
  background: rgba(255, 255, 255, 0.2);
  color: #ffffff;
}

.user-performance {
  padding-top: 20rpx;
  border-top: 2rpx solid rgba(255, 255, 255, 0.2);
  font-size: 28rpx;
}

.performance-label {
  opacity: 0.8;
}

/* 统计盒子 */
.stat-box {
  background: var(--bg-color);
  border-radius: 16rpx;
  padding: 30rpx;
  text-align: center;
}

.stat-box .stat-number {
  font-size: 44rpx;
  font-weight: 700;
  margin-bottom: 10rpx;
  color: var(--text-color);
}

.stat-box .stat-label {
  font-size: 26rpx;
  color: var(--text-color-secondary);
}

/* 菜单列表 */
.menu-list {
  padding: 0;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
}

.menu-icon {
  width: 60rpx;
  height: 60rpx;
  border-radius: 16rpx;
  background: rgba(24, 144, 255, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-right: 20rpx;
}

.menu-content {
  flex: 1;
}

.menu-title {
  display: block;
  font-size: 30rpx;
  color: var(--text-color);
  margin-bottom: 6rpx;
}

.menu-desc {
  display: block;
  font-size: 24rpx;
  color: var(--text-color-light);
}

.menu-arrow {
  font-size: 40rpx;
  color: var(--text-color-light);
}

/* 版本信息 */
.version-info {
  text-align: center;
  padding: 40rpx;
  color: var(--text-color-light);
  font-size: 24rpx;
}
