<view class="container">
  <view class="loading-state" wx:if="{{loading}}">
    <view class="loading-text">加载中...</view>
  </view>

  <block wx:if="{{!loading && orderInfo}}">
    <!-- 订单状态卡片 -->
    <view class="card status-card status-{{orderInfo.status}}">
      <view class="status-icon">
        {{orderInfo.status === 'pending' ? '📋' : 
          orderInfo.status === 'accepted' ? '🔄' : 
          orderInfo.status === 'completed' ? '✅' : '❌'}}
      </view>
      <view class="status-text">
        {{orderInfo.status === 'pending' ? '待接单' : 
          orderInfo.status === 'accepted' ? '进行中' : 
          orderInfo.status === 'completed' ? '已完成' : '已取消'}}
      </view>
      <view class="status-desc">
        {{orderInfo.status === 'pending' ? '等待手工艺人接单' : 
          orderInfo.status === 'accepted' ? '正在制作中' : 
          orderInfo.status === 'completed' ? '订单已完成' : '订单已取消'}}
      </view>
    </view>

    <!-- 订单信息 -->
    <view class="card">
      <view class="card-title">订单信息</view>
      <view class="info-list">
        <view class="info-row">
          <text class="info-label">订单名称</text>
          <text class="info-value">{{orderInfo.name}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">样式</text>
          <text class="info-value">{{orderInfo.styleName}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">数量</text>
          <text class="info-value">{{orderInfo.quantity}} 件</text>
        </view>
        <view class="info-row">
          <text class="info-label">单价</text>
          <text class="info-value text-primary">¥{{orderInfo.price}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">总价</text>
          <text class="info-value text-error text-bold">¥{{orderInfo.totalPrice}}</text>
        </view>
      </view>
    </view>

    <!-- 时间信息 -->
    <view class="card">
      <view class="card-title">时间安排</view>
      <view class="info-list">
        <view class="info-row">
          <text class="info-label">派单日期</text>
          <text class="info-value">{{orderInfo.dispatchDate}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">收货日期</text>
          <text class="info-value">{{orderInfo.receiveDate}}</text>
        </view>
        <view class="info-row" wx:if="{{orderInfo.acceptDate}}">
          <text class="info-label">接单时间</text>
          <text class="info-value">{{orderInfo.acceptDate}}</text>
        </view>
        <view class="info-row" wx:if="{{orderInfo.completeDate}}">
          <text class="info-label">完成时间</text>
          <text class="info-value">{{orderInfo.completeDate}}</text>
        </view>
      </view>
    </view>

    <!-- 接单人信息 -->
    <view class="card" wx:if="{{orderInfo.craftsmanName}}">
      <view class="card-title">接单人</view>
      <view class="info-list">
        <view class="info-row">
          <text class="info-label">姓名</text>
          <text class="info-value">{{orderInfo.craftsmanName}}</text>
        </view>
        <view class="info-row" wx:if="{{orderInfo.craftsmanPhone}}">
          <text class="info-label">联系方式</text>
          <text class="info-value">{{orderInfo.craftsmanPhone}}</text>
        </view>
      </view>
    </view>

    <!-- 备注 -->
    <view class="card" wx:if="{{orderInfo.remark}}">
      <view class="card-title">备注</view>
      <view class="remark-content">{{orderInfo.remark}}</view>
    </view>

    <!-- 操作按钮 -->
    <view class="action-area">
      <!-- 待接单状态 -->
      <block wx:if="{{orderInfo.status === 'pending'}}">
        <view class="btn btn-primary" bindtap="acceptOrder" wx:if="{{!isAdmin}}">立即接单</view>
        <view class="btn btn-default" bindtap="goBack">返回</view>
      </block>

      <!-- 进行中状态 -->
      <block wx:if="{{orderInfo.status === 'accepted'}}">
        <view class="btn btn-success" bindtap="completeOrder" wx:if="{{!isAdmin && orderInfo.craftsmanId === craftsmanInfo._id}}">完成订单</view>
        <view class="btn btn-warning" bindtap="cancelOrder">取消订单</view>
        <view class="btn btn-default" bindtap="goBack">返回</view>
      </block>

      <!-- 已完成/已取消 -->
      <block wx:if="{{orderInfo.status === 'completed' || orderInfo.status === 'cancelled'}}">
        <view class="btn btn-default" bindtap="goBack">返回</view>
      </block>
    </view>
  </block>
</view>
