/* 状态标签页 */
.status-tabs {
  display: flex;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 10rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 10rpx;
  font-size: 28rpx;
  color: var(--text-color-secondary);
  border-radius: 12rpx;
  transition: all 0.3s;
}

.tab-item.active {
  background: var(--primary-color);
  color: #ffffff;
}

/* 订单项 */
.order-item {
  position: relative;
}

.order-name {
  font-size: 32rpx;
  font-weight: 600;
  flex: 1;
  margin-right: 20rpx;
}

.create-time {
  font-size: 24rpx;
  color: var(--text-color-light);
}

.action-btns {
  display: flex;
}

/* 搜索栏调整 */
.search-bar {
  margin: -20rpx -20rpx 20rpx -20rpx;
  border-radius: 0;
}
