/* 手工艺人卡片 */
.craftsman-list {
  padding-bottom: 120rpx;
}

.craftsman-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.craftsman-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid var(--border-color);
}

.craftsman-name {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.craftsman-stars .star {
  font-size: 28rpx;
}

.craftsman-body {
  margin-bottom: 20rpx;
}

.craftsman-footer {
  display: flex;
  justify-content: flex-end;
}

/* 弹窗样式调整 */
.modal-lg {
  max-width: 640rpx;
}

.modal-body .stars .star {
  font-size: 36rpx;
  margin-right: 8rpx;
}
