/* 测试页面样式 */
.container {
  padding: 20rpx;
}

.header {
  font-size: 36rpx;
  font-weight: bold;
  text-align: center;
  margin: 40rpx 0;
}

.results {
  margin-top: 40rpx;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
}

.summary {
  display: flex;
  justify-content: space-around;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #ddd;
}

.pass { color: #07c160; }
.fail { color: #fa5151; }

.test-item {
  padding: 16rpx 0;
  font-size: 28rpx;
  border-bottom: 1rpx solid #eee;
}

.test-item.passed {
  color: #07c160;
}

.test-item.failed {
  color: #fa5151;
}
