/* Sùyǎ Artisans - Order Detail Page Styles */

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

/* Loading State */
.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

/* Info Row Suya Style */
.info-row-suya {
  padding: 16rpx 0;
}

.info-row-suya:first-child {
  padding-top: 0;
}

/* Timeline */
.timeline {
  position: relative;
  padding-left: 32rpx;
}

.timeline::before {
  content: "";
  position: absolute;
  left: 6rpx;
  top: 12rpx;
  bottom: 12rpx;
  width: 2rpx;
  background: var(--outline-variant);
  opacity: 0.3;
}

.timeline-item {
  position: relative;
  padding-bottom: 32rpx;
}

.timeline-item:last-child {
  padding-bottom: 0;
}

.timeline-dot {
  position: absolute;
  left: -32rpx;
  top: 8rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: var(--outline-variant);
}

.timeline-dot.active {
  background: var(--primary);
}

.timeline-content {
  padding-left: 16rpx;
}

/* Photo Upload */
.photo-upload-area {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed var(--outline-variant);
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: var(--surface-container-low);
  transition: all var(--duration-fast);
}

.photo-upload-area:active {
  background: var(--surface-container);
  border-color: var(--primary);
}

/* Action Area */
.action-area {
  margin-top: 48rpx;
  padding-bottom: 40rpx;
}

/* Status Card variations */
.status-pending-bg {
  background: linear-gradient(135deg, var(--tertiary) 0%, var(--tertiary-container) 100%);
}

.status-active-bg {
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-container) 100%);
}

.status-success-bg {
  background: linear-gradient(135deg, #52c41a 0%, #389e0d 100%);
}

/* Form styling */
.form-section {
  margin-top: 16rpx;
}

.form-row {
  margin-bottom: 32rpx;
}

.form-row:last-child {
  margin-bottom: 0;
}

/* Tips Box */
.tips-box {
  padding: 20rpx;
  border-radius: 16rpx;
  margin-top: 24rpx;
}

.tips-box-info {
  background: var(--primary-fixed);
}

.tips-box-warning {
  background: var(--tertiary-fixed);
}

/* Info Section */
.info-section {
  padding-top: 8rpx;
}

/* Complete Photo */
.complete-photo-wrap {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}

.complete-photo-img {
  width: 100%;
  height: 100%;
  border-radius: 16rpx;
  object-fit: cover;
}

.photo-delete-btn {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 40rpx;
  height: 40rpx;
  background: var(--error);
  color: var(--on-error);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}
