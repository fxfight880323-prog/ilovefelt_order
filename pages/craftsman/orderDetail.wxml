<view class="container canvas-bg">
  <view class="loading-state" wx:if="{{loading}}">
    <view style="text-align: center;">
      <view style="width: 80rpx; height: 80rpx; border: 4rpx solid var(--outline-variant); border-top-color: var(--primary); border-radius: 50%; margin: 0 auto 20rpx; animation: spin 1s linear infinite;"></view>
      <view style="color: var(--on-surface-variant); font-size: 28rpx;">加载中...</view>
    </view>
  </view>

  <block wx:if="{{!loading && orderInfo}}">
    <!-- Header -->
    <view class="section-header" style="padding-top: 20rpx;">
      <view class="flex items-center gap-2">
        <view class="chip" style="background: var(--surface-container); color: var(--on-surface-variant); font-size: 20rpx;">ORDER CODE</view>
      </view>
      <view class="headline-lg" style="margin-top: 12rpx;">#{{orderInfo.orderCode || orderInfo._id}}</view>
    </view>
    
    <!-- Status Chip -->
    <view style="margin-bottom: 32rpx;">
      <view class="chip" style="background: {{orderInfo.status === 'pending' ? 'var(--tertiary-fixed)' : orderInfo.status === 'accepted' ? 'var(--primary-fixed)' : orderInfo.status === 'shipped' ? '#fff7e6' : orderInfo.status === 'completed' ? '#e6f7e6' : orderInfo.status === 'closed' ? '#fff1f0' : 'var(--surface-container)'}}; color: {{orderInfo.status === 'pending' ? 'var(--on-tertiary-fixed)' : orderInfo.status === 'accepted' ? 'var(--on-primary-fixed)' : orderInfo.status === 'shipped' ? '#fa8c16' : orderInfo.status === 'completed' ? '#52c41a' : orderInfo.status === 'closed' ? '#cf1322' : 'var(--on-surface-variant)'}};">
        <text style="margin-right: 8rpx;">●</text>
        {{orderInfo.status === 'pending' ? '待接单' : orderInfo.status === 'accepted' ? '进行中' : orderInfo.status === 'shipped' ? '已发货' : orderInfo.status === 'completed' ? '已完成' : orderInfo.status === 'closed' ? '已撤回' : '已取消'}}
      </view>
      <!-- 收款状态（新流程：已发货显示待收款/已收款） -->
      <view class="chip" wx:if="{{orderInfo.status === 'shipped' || orderInfo.status === 'completed'}}" style="margin-left: 16rpx; background: {{orderInfo.status === 'shipped' ? '#fff7e6' : '#f6ffed'}}; color: {{orderInfo.status === 'shipped' ? '#fa8c16' : '#389e0d'}};">
        <text style="margin-right: 8rpx;">💰</text>
        {{orderInfo.status === 'shipped' ? '待收款' : '已收款'}}
      </view>
    </view>

    <!-- Status Card -->
    <view class="card card-primary" style="margin-bottom: 32rpx; position: relative; overflow: hidden;">
      <view style="position: relative; z-index: 1;">
        <view style="font-size: 64rpx; margin-bottom: 16rpx;">
          {{orderInfo.status === 'pending' ? '📋' : orderInfo.status === 'accepted' ? '🔄' : orderInfo.status === 'shipped' ? '🚚' : orderInfo.status === 'completed' ? '✅' : orderInfo.status === 'closed' ? '🔒' : '❌'}}
        </view>
        <view class="title-lg" style="margin-bottom: 8rpx;">
          {{orderInfo.status === 'pending' ? '等待手工艺人接单' : orderInfo.status === 'accepted' ? '正在制作中' : orderInfo.status === 'shipped' ? '订单已发货，等待确认收款' : orderInfo.status === 'completed' ? '订单已完成' : orderInfo.status === 'closed' ? '订单已撤回' : '订单已取消'}}
        </view>
        <view wx:if="{{orderInfo.craftsmanName}}" style="font-size: 26rpx; opacity: 0.8; margin-top: 16rpx;">
          接单人：{{orderInfo.craftsmanName}}
        </view>
        <!-- 付款信息 -->
        <view wx:if="{{orderInfo.paymentStatus && orderInfo.paymentStatus !== 'unpaid'}}" style="margin-top: 24rpx; padding: 16rpx 24rpx; background: rgba(255,255,255,0.15); border-radius: 12rpx;">
          <view style="font-size: 24rpx; opacity: 0.9;">
            <text wx:if="{{orderInfo.paymentStatus === 'pending_receipt'}}">付款已确认，等待手艺人收款</text>
            <text wx:if="{{orderInfo.paymentStatus === 'paid'}}">收款已确认，订单已结束</text>
          </view>
          <view wx:if="{{orderInfo.paymentConfirmedAt}}" style="font-size: 22rpx; opacity: 0.7; margin-top: 8rpx;">
            付款时间：{{orderInfo.paymentConfirmedAt}}
          </view>
        </view>
      </view>
      <!-- Decorative -->
      <view style="position: absolute; top: -40rpx; right: -40rpx; width: 200rpx; height: 200rpx; background: rgba(255,255,255,0.05); border-radius: 50%;"></view>
    </view>

    <!-- Tracking Info -->
    <view class="card" wx:if="{{orderInfo.trackingNumber || showTrackingInput}}">
      <view class="card-title">物流信息</view>
      
      <!-- Display tracking -->
      <view wx:if="{{orderInfo.trackingNumber}}">
        <view class="info-row-suya">
          <view class="label-sm" style="margin-bottom: 8rpx;">物流公司</view>
          <view class="body-md">{{orderInfo.trackingCompany || '其他快递'}}</view>
        </view>
        <view class="info-row-suya" style="margin-top: 24rpx;">
          <view class="label-sm" style="margin-bottom: 8rpx;">运单号</view>
          <view class="flex items-center gap-3">
            <view class="title-sm text-primary" style="font-family: monospace;">{{orderInfo.trackingNumber}}</view>
            <view class="chip chip-outline" style="font-size: 20rpx;" bindtap="copyTrackingNumber">复制</view>
          </view>
        </view>
      </view>
      
      <!-- Input tracking -->
      <view wx:if="{{showTrackingInput}}" style="margin-top: 16rpx;">
        <view class="input-field">
          <view class="input-label">物流公司</view>
          <picker mode="selector" range="{{trackingCompanies}}" value="{{companyIndex}}" bindchange="onCompanyChange">
            <view style="padding: 24rpx 0; border-bottom: 2rpx solid var(--outline-variant); font-size: 30rpx; color: var(--on-surface);">
              {{trackingCompanies[companyIndex]}}
            </view>
          </picker>
        </view>
        <view class="input-field">
          <view class="input-label">运单号 *</view>
          <input 
            class="input"
            placeholder="请粘贴运单号"
            value="{{trackingNumber}}"
            bindinput="onTrackingInput"
          />
        </view>
        <view style="margin-top: 24rpx; padding: 20rpx; background: var(--tertiary-fixed); border-radius: 16rpx;">
          <view style="font-size: 24rpx; color: var(--on-tertiary-fixed-variant);">提示：请确保运单号正确，方便买家查询物流</view>
        </view>
      </view>
    </view>

    <!-- Complete Photos -->
    <view class="card" wx:if="{{showCompleteSection || orderInfo.completePhotoUrls}}">
      <view class="card-title">完成订单照片</view>
      
      <!-- Display photos -->
      <view wx:if="{{orderInfo.completePhotoUrls && orderInfo.completePhotoUrls.length > 0}}">
        <view style="display: flex; flex-wrap: wrap; gap: 20rpx;">
          <image 
            wx:for="{{orderInfo.completePhotoUrls}}" 
            wx:key="index"
            src="{{item}}" 
            style="width: 200rpx; height: 200rpx; border-radius: 16rpx; object-fit: cover;"
            mode="aspectFill"
            bindtap="previewPhoto"
            data-url="{{item}}"
          />
        </view>
      </view>
      
      <!-- Upload photos -->
      <view wx:if="{{showCompleteSection}}" style="margin-top: 16rpx;">
        <view style="display: flex; flex-wrap: wrap; gap: 20rpx;">
          <view wx:for="{{completePhotos}}" wx:key="index" style="position: relative; width: 200rpx; height: 200rpx;">
            <image src="{{item}}" style="width: 100%; height: 100%; border-radius: 16rpx; object-fit: cover;" mode="aspectFill"/>
            <view style="position: absolute; top: -10rpx; right: -10rpx; width: 40rpx; height: 40rpx; background: var(--error); color: var(--on-error); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 24rpx;" bindtap="deletePhoto" data-index="{{index}}">×</view>
          </view>
          <view style="width: 200rpx; height: 200rpx; border: 2rpx dashed var(--outline-variant); border-radius: 16rpx; display: flex; flex-direction: column; align-items: center; justify-content: center; background: var(--surface-container-low);" bindtap="choosePhoto" wx:if="{{completePhotos.length < 3}}">
            <text style="font-size: 48rpx; margin-bottom: 8rpx;">📷</text>
            <text style="font-size: 26rpx; color: var(--on-surface-variant);">拍照上传</text>
            <text style="font-size: 22rpx; color: var(--outline); margin-top: 8rpx;">最多3张</text>
          </view>
        </view>
        <view wx:if="{{completePhotos.length === 0}}" style="margin-top: 24rpx; padding: 20rpx; background: var(--primary-fixed); border-radius: 16rpx;">
          <view style="font-size: 24rpx; color: var(--on-primary-fixed-variant);">请拍摄完成作品的照片，作为订单完成证明</view>
        </view>
      </view>
    </view>

    <!-- Order Info -->
    <view class="card">
      <view class="card-title">订单详情</view>
      <view class="info-section">
        <view class="info-row-suya">
          <view class="label-sm">订单名称</view>
          <view class="body-md" style="margin-top: 8rpx;">{{orderInfo.name}}</view>
        </view>
        <view class="info-row-suya">
          <view class="label-sm">样式</view>
          <view class="body-md" style="margin-top: 8rpx;">{{orderInfo.styleName}}</view>
        </view>
        <view style="display: grid; grid-template-columns: 1fr 1fr; gap: 24rpx; margin-top: 24rpx; padding-top: 24rpx; border-top: 2rpx solid var(--outline-variant); border-top-opacity: 0.15;">
          <view>
            <view class="label-sm" style="margin-bottom: 8rpx;">数量</view>
            <view class="title-sm">{{orderInfo.quantity}} 件</view>
          </view>
          <view>
            <view class="label-sm" style="margin-bottom: 8rpx;">单价</view>
            <view class="title-sm text-primary">¥{{orderInfo.price}}</view>
          </view>
        </view>
        <view style="margin-top: 24rpx; padding: 24rpx; background: var(--surface-container); border-radius: 16rpx;">
          <view class="label-sm" style="margin-bottom: 8rpx;">总价</view>
          <view class="headline-sm text-primary">¥{{orderInfo.totalPrice}}</view>
        </view>
      </view>
    </view>

    <!-- Timeline -->
    <view class="card">
      <view class="card-title">时间安排</view>
      <view class="timeline">
        <view class="timeline-item">
          <view class="timeline-dot"></view>
          <view class="timeline-content">
            <view class="label-sm" style="margin-bottom: 4rpx;">派单日期</view>
            <view class="body-md">{{orderInfo.dispatchDate}}</view>
          </view>
        </view>
        <view class="timeline-item">
          <view class="timeline-dot"></view>
          <view class="timeline-content">
            <view class="label-sm" style="margin-bottom: 4rpx;">收货日期</view>
            <view class="body-md">{{orderInfo.receiveDate}}</view>
          </view>
        </view>
        <view class="timeline-item" wx:if="{{orderInfo.acceptDate}}">
          <view class="timeline-dot active"></view>
          <view class="timeline-content">
            <view class="label-sm" style="margin-bottom: 4rpx;">接单时间</view>
            <view class="body-md">{{orderInfo.acceptDate}}</view>
          </view>
        </view>
        <view class="timeline-item" wx:if="{{orderInfo.shipDate}}">
          <view class="timeline-dot active"></view>
          <view class="timeline-content">
            <view class="label-sm" style="margin-bottom: 4rpx;">发货时间</view>
            <view class="body-md">{{orderInfo.shipDate}}</view>
          </view>
        </view>
        <view class="timeline-item" wx:if="{{orderInfo.completeDate}}">
          <view class="timeline-dot active"></view>
          <view class="timeline-content">
            <view class="label-sm" style="margin-bottom: 4rpx;">完成时间</view>
            <view class="body-md">{{orderInfo.completeDate}}</view>
          </view>
        </view>
      </view>
    </view>

    <!-- Craftsman Info -->
    <view class="card" wx:if="{{orderInfo.craftsmanName}}">
      <view class="card-title">接单人</view>
      <view class="info-section">
        <view class="info-row-suya">
          <view class="label-sm">姓名</view>
          <view class="body-md" style="margin-top: 8rpx;">{{orderInfo.craftsmanName}}</view>
        </view>
        <view class="info-row-suya" wx:if="{{orderInfo.craftsmanPhone}}" style="margin-top: 24rpx;">
          <view class="label-sm">联系方式</view>
          <view class="body-md" style="margin-top: 8rpx;">{{orderInfo.craftsmanPhone}}</view>
        </view>
      </view>
    </view>

    <!-- Remark -->
    <view class="card" wx:if="{{orderInfo.remark}}">
      <view class="card-title">备注</view>
      <view style="padding: 24rpx; background: var(--surface-container); border-radius: 16rpx;">
        <view class="body-md text-on-surface-variant" style="font-style: italic; line-height: 1.8;">{{orderInfo.remark}}</view>
      </view>
    </view>

    <!-- Action Buttons -->
    <view style="margin-top: 48rpx; padding-bottom: 40rpx;">
      <!-- Pending -->
      <block wx:if="{{orderInfo.status === 'pending'}}">
        <view class="btn btn-primary btn-full" bindtap="acceptOrder">立即接单</view>
        <view class="btn btn-tertiary btn-full" style="margin-top: 20rpx;" bindtap="goBack">返回</view>
      </block>

      <!-- Accepted -->
      <block wx:if="{{orderInfo.status === 'accepted' && !showTrackingInput && !showCompleteSection}}">
        <view class="btn btn-primary btn-full" bindtap="showTrackingInput">填写运单号</view>
        <view class="btn btn-outline btn-full" style="margin-top: 20rpx;" bindtap="cancelOrder">取消订单</view>
        <view class="btn btn-tertiary btn-full" style="margin-top: 20rpx;" bindtap="goBack">返回</view>
      </block>

      <!-- Tracking Input -->
      <block wx:if="{{showTrackingInput}}">
        <view class="btn btn-primary btn-full" bindtap="submitTracking">提交运单号</view>
        <view class="btn btn-tertiary btn-full" style="margin-top: 20rpx;" bindtap="hideTrackingInput">取消</view>
      </block>

      <!-- Shipped - 已发货（新流程：可上传照片 + 确认收款） -->
      <block wx:if="{{orderInfo.status === 'shipped' && !showCompleteSection}}">
        <!-- 未上传照片：显示完成订单按钮 -->
        <block wx:if="{{!orderInfo.completePhotos || orderInfo.completePhotos.length === 0}}">
          <view class="btn btn-primary btn-full" bindtap="showCompleteSection">完成订单（上传照片）</view>
          <view style="margin-top: 16rpx; padding: 20rpx; background: var(--surface-container); border-radius: 12rpx;">
            <view style="font-size: 24rpx; color: var(--on-surface-variant);">请先上传货品照片，然后确认收款</view>
          </view>
        </block>
        <!-- 已上传照片：显示确认收款按钮 -->
        <block wx:if="{{orderInfo.completePhotos && orderInfo.completePhotos.length > 0}}">
          <view class="btn btn-success btn-full" bindtap="confirmReceipt" style="background: #52c41a; color: white;">✅ 确认收款</view>
          <view style="margin-top: 16rpx; padding: 20rpx; background: #f6ffed; border-radius: 12rpx; border: 2rpx solid #b7eb8f;">
            <view style="font-size: 24rpx; color: #389e0d; font-weight: 500;">照片已上传，请点击确认收款</view>
            <view style="font-size: 22rpx; color: #73d13d; margin-top: 8rpx;">确认后订单将标记为已完成</view>
          </view>
        </block>
        <view class="btn btn-tertiary btn-full" style="margin-top: 20rpx;" bindtap="goBack">返回</view>
      </block>

      <!-- Complete Section（上传照片） -->
      <block wx:if="{{showCompleteSection}}">
        <view class="btn btn-primary btn-full" bindtap="submitComplete" wx:if="{{completePhotos.length > 0}}">提交照片</view>
        <view class="btn btn-tertiary btn-full" style="margin-top: 20rpx;" bindtap="hideCompleteSection">取消</view>
      </block>

      <!-- Completed - 已完成（已收款） -->
      <block wx:if="{{orderInfo.status === 'completed'}}">
        <view class="btn btn-success btn-full" style="background: #52c41a; color: white;">✅ 订单已完成</view>
        <view style="margin-top: 16rpx; padding: 20rpx; background: #f6ffed; border-radius: 12rpx; border: 2rpx solid #b7eb8f;">
          <view style="font-size: 24rpx; color: #389e0d;">收款已确认，订单已完成</view>
        </view>
        <view class="btn btn-tertiary btn-full" style="margin-top: 20rpx;" bindtap="goBack">返回</view>
      </block>

      <!-- Closed - 已撤回 -->
      <block wx:if="{{orderInfo.status === 'closed'}}">
        <view class="btn btn-error btn-full" style="background: #ff4d4f; color: white;">❌ 订单已撤回</view>
        <view style="margin-top: 16rpx; padding: 20rpx; background: #fff1f0; border-radius: 12rpx; border: 2rpx solid #ffa39e;">
          <view style="font-size: 24rpx; color: #cf1322;">该订单已被撤回</view>
        </view>
        <view class="btn btn-tertiary btn-full" style="margin-top: 20rpx;" bindtap="goBack">返回</view>
      </block>

      <!-- Cancelled -->
      <block wx:if="{{orderInfo.status === 'cancelled'}}">
        <view class="btn btn-tertiary btn-full" bindtap="goBack">返回</view>
      </block>
    </view>
    
    <!-- Bottom Spacer -->
    <view style="height: 40rpx;"></view>
  </block>
</view>
