/* Sùyǎ Artisans - My Orders Page Styles */

/* Tab Item */
.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 10rpx;
  font-size: 28rpx;
  color: var(--on-surface-variant);
  border-radius: 12rpx;
  transition: all var(--duration-fast);
}

.tab-item.active {
  background: var(--primary);
  color: var(--on-primary);
  box-shadow: var(--shadow-sm);
}

/* Order Card */
.order-card {
  transition: transform var(--duration-fast), box-shadow var(--duration-fast);
}

.order-card:active {
  transform: translateY(4rpx);
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

/* Info Grid in Order Card */
.order-info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

/* Total Price Box */
.price-box {
  padding: 20rpx;
  background: var(--surface-container);
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

/* Footer Actions */
.order-footer {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid var(--outline-variant);
  border-top-opacity: 0.15;
}
