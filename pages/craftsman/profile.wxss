/* Sùyǎ Artisans - Profile Page Styles */

/* Profile Hero */
.profile-hero {
  padding: 48rpx 40rpx;
  background: linear-gradient(180deg, var(--surface-variant) 0%, var(--surface) 60%);
  margin: -20rpx -20rpx 32rpx;
  position: relative;
}

.profile-hero::before {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 200rpx;
  background: var(--surface-variant);
  opacity: 0.5;
}

/* Avatar Section */
.avatar-section {
  display: flex;
  justify-content: center;
  position: relative;
  z-index: 1;
}

.avatar-main {
  width: 280rpx;
  height: 350rpx;
  border-radius: 24rpx;
  object-fit: cover;
  box-shadow: var(--shadow-lg);
  border: 8rpx solid var(--surface);
  transition: opacity var(--duration-fast);
}

.avatar-main:active {
  opacity: 0.8;
}

.avatar-badge-main {
  position: absolute;
  bottom: -16rpx;
  right: -16rpx;
  width: 64rpx;
  height: 64rpx;
  background: var(--primary);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--on-primary);
  box-shadow: var(--shadow-md);
  border: 6rpx solid var(--surface);
  transform: rotate(6deg);
}

/* Stats Row */
.stats-row {
  display: flex;
  justify-content: center;
  gap: 64rpx;
  padding-top: 32rpx;
  border-top: 2rpx solid var(--outline-variant);
  border-top-opacity: 0.15;
  max-width: 500rpx;
  margin: 0 auto;
}

.stat-block {
  text-align: center;
  padding: 16rpx;
  border-radius: 16rpx;
  transition: all var(--duration-fast);
  position: relative;
}

.stat-block:active {
  background: var(--surface-container);
  transform: scale(0.98);
}

/* 可点击的统计块 */
.stat-block-clickable {
  cursor: pointer;
}

.stat-block-clickable::after {
  content: '';
  position: absolute;
  bottom: 4rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: var(--primary);
  opacity: 0.5;
}

.stat-block .stat-value {
  font-size: 44rpx;
  font-weight: 800;
  color: var(--primary);
  letter-spacing: -0.02em;
  margin-bottom: 8rpx;
}

.stat-block .stat-label {
  font-size: 22rpx;
  color: var(--on-surface-variant);
  letter-spacing: 0.1em;
  text-transform: uppercase;
}

/* Menu List in Profile */
.menu-list {
  display: flex;
  flex-direction: column;
}

.menu-icon-wrap {
  margin-right: 24rpx;
}

.menu-icon-inner {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  transition: all var(--duration-fast);
}

.menu-item:active .menu-icon-inner {
  transform: scale(0.95);
}

/* Specialty Text */
.specialty-text {
  font-style: italic;
  color: var(--on-surface-variant);
  line-height: 1.6;
  max-width: 500rpx;
  margin: 0 auto;
}

/* Performance Card */
.performance-card {
  background: var(--tertiary-fixed);
  padding: 32rpx;
  border-radius: 24rpx;
  margin-bottom: 32rpx;
}

.performance-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--on-tertiary-fixed);
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.performance-value {
  font-size: 32rpx;
  color: var(--on-tertiary-fixed-variant);
}
