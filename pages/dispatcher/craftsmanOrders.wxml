<view class="container">
  <!-- Header -->
  <view class="header">
    <view class="title">{{craftsmanName}}</view>
    <view class="subtitle">历史订单记录</view>
  </view>

  <!-- Stats Card -->
  <view class="stats-card" wx:if="{{stats}}">
    <view class="stat-item">
      <text class="stat-value">{{stats.total}}</text>
      <text class="stat-label">总订单</text>
    </view>
    <view class="stat-item">
      <text class="stat-value">{{stats.completed}}</text>
      <text class="stat-label">已完成</text>
    </view>
    <view class="stat-item">
      <text class="stat-value">{{stats.pending}}</text>
      <text class="stat-label">进行中</text>
    </view>
  </view>

  <!-- Filter Tabs -->
  <view class="filter-bar">
    <view class="filter-item {{currentFilter === 'all' ? 'active' : ''}}" bindtap="switchFilter" data-filter="all">
      全部
    </view>
    <view class="filter-item {{currentFilter === 'pending' ? 'active' : ''}}" bindtap="switchFilter" data-filter="pending">
      待接单
    </view>
    <view class="filter-item {{currentFilter === 'accepted' ? 'active' : ''}}" bindtap="switchFilter" data-filter="accepted">
      进行中
    </view>
    <view class="filter-item {{currentFilter === 'completed' ? 'active' : ''}}" bindtap="switchFilter" data-filter="completed">
      已完成
    </view>
  </view>

  <!-- Order List -->
  <view class="order-list">
    <block wx:if="{{filteredOrders.length > 0}}">
      <view class="order-card" wx:for="{{filteredOrders}}" wx:key="_id">
        <view class="order-header">
          <view class="order-code">#{{item.orderCode || item._id}}</view>
          <view class="status-badge status-{{item.status}}">
            {{item.status === 'pending' ? '待接单' : item.status === 'accepted' ? '进行中' : item.status === 'shipped' ? '已发货' : item.status === 'completed' ? '已完成' : '已关闭'}}
          </view>
        </view>

        <view class="order-info" bindtap="viewOrderDetail" data-id="{{item._id}}">
          <view class="info-row">
            <text class="label">订单名称：</text>
            <text class="value">{{item.name}}</text>
          </view>
          <view class="info-row">
            <text class="label">样式：</text>
            <text class="value">{{item.styleName || '-'}}</text>
          </view>
          <view class="info-row">
            <text class="label">数量：</text>
            <text class="value">{{item.quantity}} 件</text>
          </view>
          <view class="info-row">
            <text class="label">总价：</text>
            <text class="value price">¥{{item.totalPrice}}</text>
          </view>
          <view class="info-row">
            <text class="label">创建时间：</text>
            <text class="value">{{item.createTime}}</text>
          </view>
          <view class="info-row" wx:if="{{item.completeDate}}">
            <text class="label">完成时间：</text>
            <text class="value">{{item.completeDate}}</text>
          </view>
        </view>

        <!-- Actions -->
        <view class="order-actions">
          <view class="action-btn btn-view" bindtap="viewOrderDetail" data-id="{{item._id}}">查看详情</view>
          <view class="action-btn btn-rate" wx:if="{{item.status === 'completed' && !item.rating}}" bindtap="rateOrder" data-id="{{item._id}}">评价</view>
          <view class="rated-tag" wx:if="{{item.status === 'completed' && item.rating}}">已评价 {{item.rating}}★</view>
        </view>
      </view>
    </block>

    <!-- Empty State -->
    <view class="empty-state" wx:if="{{!loading && filteredOrders.length === 0}}">
      <view class="empty-icon">📭</view>
      <view class="empty-text">暂无订单</view>
    </view>
  </view>

  <!-- Loading -->
  <view class="loading-mask" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text>加载中...</text>
  </view>
</view>
