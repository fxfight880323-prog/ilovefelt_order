<view class="container">
  <!-- Header -->
  <view class="header">
    <view class="title">订单详情</view>
    <view class="order-code">#{{orderInfo.orderCode || orderInfo._id}}</view>
  </view>

  <!-- 加载中 -->
  <view class="loading-state" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text>加载中...</text>
  </view>

  <!-- 订单内容 -->
  <block wx:if="{{!loading && orderInfo}}">
    <!-- 状态卡片 -->
    <view class="card status-card">
      <view class="status-icon">📦</view>
      <view class="status-text">
        {{orderInfo.status === 'pending' ? '待接单' : 
          orderInfo.status === 'accepted' ? '进行中' : 
          orderInfo.status === 'shipped' ? '已发货' : 
          orderInfo.status === 'completed' ? '已完成' : '已关闭'}}
      </view>
      <view class="status-desc" wx:if="{{orderInfo.craftsmanName}}">
        接单人：{{orderInfo.craftsmanName}}
      </view>
    </view>

    <!-- 订单信息 -->
    <view class="card">
      <view class="card-title">订单信息</view>
      <view class="info-list">
        <view class="info-item">
          <text class="label">订单名称</text>
          <text class="value">{{orderInfo.name}}</text>
        </view>
        <view class="info-item">
          <text class="label">样式</text>
          <text class="value">{{orderInfo.styleName || '-'}}</text>
        </view>
        <view class="info-item">
          <text class="label">数量</text>
          <text class="value">{{orderInfo.quantity}} 件</text>
        </view>
        <view class="info-item">
          <text class="label">单价</text>
          <text class="value price">¥{{orderInfo.price}}</text>
        </view>
        <view class="info-item">
          <text class="label">总价</text>
          <text class="value price">¥{{orderInfo.totalPrice}}</text>
        </view>
        <view class="info-item" wx:if="{{orderInfo.receiveDate}}">
          <text class="label">约定收货日期</text>
          <text class="value">{{orderInfo.receiveDate}}</text>
        </view>
        <view class="info-item">
          <text class="label">创建时间</text>
          <text class="value">{{orderInfo.createTime}}</text>
        </view>
        <view class="info-item" wx:if="{{orderInfo.remark}}">
          <text class="label">备注</text>
          <text class="value">{{orderInfo.remark}}</text>
        </view>
      </view>
    </view>

    <!-- 手艺人信息 -->
    <view class="card" wx:if="{{orderInfo.craftsmanName}}">
      <view class="card-title">手艺人信息</view>
      <view class="info-list">
        <view class="info-item">
          <text class="label">姓名</text>
          <text class="value">{{orderInfo.craftsmanName}}</text>
        </view>
        <view class="info-item" wx:if="{{orderInfo.craftsmanPhone}}">
          <text class="label">电话</text>
          <text class="value">{{orderInfo.craftsmanPhone}}</text>
        </view>
      </view>
    </view>

    <!-- 物流信息 -->
    <view class="card" wx:if="{{orderInfo.trackingNumber}}">
      <view class="card-title">物流信息</view>
      <view class="info-list">
        <view class="info-item">
          <text class="label">物流公司</text>
          <text class="value">{{orderInfo.trackingCompany || '-'}}</text>
        </view>
        <view class="info-item">
          <text class="label">运单号</text>
          <text class="value">{{orderInfo.trackingNumber}}</text>
        </view>
        <view class="info-item" wx:if="{{orderInfo.shipDate}}">
          <text class="label">发货时间</text>
          <text class="value">{{orderInfo.shipDate}}</text>
        </view>
      </view>
    </view>

    <!-- 完成照片 -->
    <view class="card" wx:if="{{orderInfo.completePhotos && orderInfo.completePhotos.length > 0}}">
      <view class="card-title">完成照片</view>
      <view class="photo-list">
        <image 
          wx:for="{{orderInfo.completePhotos}}" 
          wx:key="index"
          class="photo-item"
          src="{{item}}"
          mode="aspectFill"
          bindtap="previewPhoto"
          data-url="{{item}}"
        />
      </view>
    </view>

    <!-- 评价信息 -->
    <view class="card" wx:if="{{orderInfo.rating}}">
      <view class="card-title">我的评价</view>
      <view class="rating-display">
        <text class="star" wx:for="{{5}}" wx:key="index">{{index < orderInfo.rating ? '★' : '☆'}}</text>
        <text class="rating-score">{{orderInfo.rating}} 分</text>
      </view>
      <view class="rating-comment" wx:if="{{orderInfo.ratingComment}}">
        {{orderInfo.ratingComment}}
      </view>
    </view>
  </block>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!loading && !orderInfo}}">
    <view class="empty-icon">📭</view>
    <view class="empty-text">订单不存在</view>
  </view>
</view>
