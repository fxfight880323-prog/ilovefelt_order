.header {
  text-align: center;
  padding: 40rpx 0;
}

.title {
  font-size: 40rpx;
  font-weight: 600;
  color: #333;
  display: block;
}

.subtitle {
  font-size: 28rpx;
  color: #999;
  margin-top: 10rpx;
  display: block;
}

.action-area {
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 12rpx;
  font-size: 32rpx;
  border: none;
}

.btn-primary {
  background: linear-gradient(135deg, #1890ff 0%, #36cfc9 100%);
  color: #fff;
}

.btn-success {
  background: linear-gradient(135deg, #52c41a 0%, #389e0d 100%);
  color: #fff;
}

.btn-default {
  background: #f5f5f5;
  color: #666;
  margin: 30rpx;
  width: calc(100% - 60rpx);
}

.btn[disabled] {
  opacity: 0.6;
}

.result-area {
  margin: 30rpx;
  padding: 30rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.result-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.result-summary {
  display: flex;
  justify-content: space-around;
  margin-bottom: 30rpx;
}

.summary-item {
  text-align: center;
  padding: 20rpx;
}

.summary-item .label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.summary-item .value {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
}

.summary-item.success .value {
  color: #52c41a;
}

.summary-item.info .value {
  color: #1890ff;
}

.summary-item.error .value {
  color: #ff4d4f;
}

.collection-list {
  margin-top: 30rpx;
}

.list-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.collection-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.collection-item.created {
  background: #f6ffed;
  border: 2rpx solid #b7eb8f;
}

.collection-item.exists {
  background: #e6f7ff;
  border: 2rpx solid #91d5ff;
}

.collection-item.error {
  background: #fff2f0;
  border: 2rpx solid #ffccc7;
}

.collection-item.missing {
  background: #fffbe6;
  border: 2rpx solid #ffe58f;
}

.item-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  display: block;
}

.item-desc {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
  display: block;
}

.item-status {
  font-size: 26rpx;
}

.tips-area {
  margin: 30rpx;
  padding: 30rpx;
  background: #fffbe6;
  border-radius: 16rpx;
  border: 2rpx solid #ffe58f;
}

.tips-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #d48806;
  margin-bottom: 16rpx;
}

.tips-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.tip-item {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}
