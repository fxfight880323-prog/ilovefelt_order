/* 容器居中 */
.container {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 36rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 30rpx;
  color: #333;
}

/* 表单项居中 */
.form-item {
  margin-bottom: 30rpx;
}

.form-label {
  display: block;
  font-size: 30rpx;
  color: #333;
  margin-bottom: 16rpx;
}

.form-label.required::before {
  content: '* ';
  color: #ff4d4f;
}

.form-input {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 20rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  font-size: 30rpx;
  box-sizing: border-box;
}

.form-picker {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 20rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  font-size: 30rpx;
  box-sizing: border-box;
  background: #fff;
}

.form-textarea {
  width: 100%;
  height: 160rpx;
  padding: 20rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  font-size: 30rpx;
  box-sizing: border-box;
}

/* 头像上传 */
.avatar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-upload {
  width: 200rpx;
  height: 200rpx;
  border: 4rpx dashed #d9d9d9;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fafafa;
}

.avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 16rpx;
}

.avatar-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-icon {
  font-size: 60rpx;
  margin-bottom: 10rpx;
}

.avatar-text {
  font-size: 26rpx;
  color: #999;
}

/* 样式选择区域 */
.style-select-area {
  margin-bottom: 20rpx;
}

.style-select-area picker {
  width: 100%;
}

/* 样式标签 */
.style-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.style-tag {
  padding: 12rpx 24rpx;
  background: #f5f5f5;
  border-radius: 30rpx;
  font-size: 28rpx;
  color: #666;
  border: 2rpx solid transparent;
}

.style-tag.active {
  background: #e6f7ff;
  color: #1890ff;
  border-color: #1890ff;
}

/* 新建样式区域 */
.new-style-section {
  margin-top: 20rpx;
}

.new-style-input {
  margin-top: 20rpx;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
}

.new-style-actions {
  display: flex;
  justify-content: flex-end;
  gap: 20rpx;
  margin-top: 20rpx;
}

/* 按钮样式 */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0 30rpx;
  height: 72rpx;
  border-radius: 36rpx;
  font-size: 28rpx;
  border: none;
}

.btn::after {
  border: none;
}

.btn-primary {
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  color: #fff;
}

.btn-default {
  background: #f5f5f5;
  color: #666;
}

.btn-sm {
  height: 60rpx;
  padding: 0 24rpx;
  font-size: 26rpx;
}

/* 提交区域 */
.submit-area {
  margin-top: 40rpx;
  padding: 0 20rpx;
}

.submit-area .btn {
  width: 100%;
}
