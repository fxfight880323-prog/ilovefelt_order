<view class="container">
  <!-- 头部 -->
  <view class="header">
    <view class="back-btn" bindtap="onBack">← 返回</view>
    <view class="title">订单管理</view>
    <view class="refresh-btn" bindtap="onRefresh">刷新</view>
  </view>

  <!-- 统计卡片 -->
  <view class="stats-card">
    <view class="stats-item">
      <view class="stats-number">{{total}}</view>
      <view class="stats-label">总订单</view>
    </view>
  </view>

  <!-- 筛选栏 -->
  <view class="filter-bar">
    <view class="filter-tabs">
      <view class="filter-tab {{statusFilter === '' ? 'active' : ''}}" 
            bindtap="onStatusChange" data-status="">全部</view>
      <view class="filter-tab {{statusFilter === 'pending' ? 'active' : ''}}" 
            bindtap="onStatusChange" data-status="pending">待接单</view>
      <view class="filter-tab {{statusFilter === 'accepted' ? 'active' : ''}}" 
            bindtap="onStatusChange" data-status="accepted">进行中</view>
      <view class="filter-tab {{statusFilter === 'completed' ? 'active' : ''}}" 
            bindtap="onStatusChange" data-status="completed">已完成</view>
    </view>
  </view>

  <!-- 搜索栏 -->
  <view class="search-bar">
    <input class="search-input" 
           placeholder="搜索订单号" 
           value="{{orderNo}}"
           bindinput="onOrderNoInput"
           confirm-type="search"
           bindconfirm="onSearch"/>
    <view class="search-btn" bindtap="onSearch">搜索</view>
  </view>

  <!-- 列表 -->
  <view class="list-container">
    <view wx:if="{{list.length === 0 && !isLoading}}" class="empty-state">
      <text class="empty-icon">📦</text>
      <text class="empty-text">暂无订单</text>
    </view>

    <view class="order-list">
      <view wx:for="{{list}}" wx:key="_id" class="order-item">
        <view class="order-header">
          <text class="order-no">{{item.orderNo}}</text>
          <text class="order-status {{item.status}}">{{item.statusText}}</text>
        </view>
        <view class="order-body">
          <view class="order-name">{{item.name}}</view>
          <view class="order-info">
            <text>数量: {{item.quantity}}</text>
            <text>单价: ¥{{item.price}}</text>
            <text class="order-amount">总价: ¥{{item.totalAmount}}</text>
          </view>
          <view class="order-users">
            <text>派单人: {{item.dispatcherName || '-'}}</text>
            <text>手艺人: {{item.craftsmanName || '未分配'}}</text>
          </view>
          <view wx:if="{{item.remark}}" class="order-remark">备注: {{item.remark}}</view>
          <view wx:if="{{item.trackingNo}}" class="order-tracking">快递单号: {{item.trackingNo}}</view>
          <view class="order-time">创建时间: {{item.createTimeText}}</view>
        </view>
        <view class="order-footer">
          <button class="btn-edit" size="mini" bindtap="onEdit" data-id="{{item._id}}">编辑</button>
          <button wx:if="{{item.status !== 'cancelled' && item.status !== 'completed'}}" 
                  class="btn-cancel" size="mini" 
                  bindtap="onCancel" 
                  data-id="{{item._id}}" 
                  data-order-no="{{item.orderNo}}">取消</button>
          <button class="btn-delete" size="mini" 
                  bindtap="onDelete" 
                  data-id="{{item._id}}" 
                  data-order-no="{{item.orderNo}}">删除</button>
        </view>
      </view>
    </view>

    <!-- 加载更多 -->
    <view wx:if="{{hasMore}}" class="load-more" bindtap="loadMore">
      <text wx:if="{{!isLoading}}">点击加载更多</text>
      <text wx:else>加载中...</text>
    </view>
    <view wx:else class="no-more">没有更多了</view>
  </view>

  <!-- 编辑弹窗 -->
  <view wx:if="{{showEdit}}" class="modal-mask" bindtap="hideEditModal">
    <view class="modal-content" catchtap="preventBubble">
      <view class="modal-header">
        <text class="modal-title">编辑订单</text>
        <text class="modal-close" bindtap="hideEditModal">×</text>
      </view>
      <view class="modal-body">
        <view class="form-item">
          <text class="form-label">订单名称</text>
          <input class="form-input" value="{{editForm.name}}" 
                 data-field="name" bindinput="onEditInput" placeholder="请输入订单名称"/>
        </view>
        <view class="form-item">
          <text class="form-label">数量</text>
          <input class="form-input" value="{{editForm.quantity}}" 
                 data-field="quantity" bindinput="onEditInput" 
                 placeholder="请输入数量" type="number"/>
        </view>
        <view class="form-item">
          <text class="form-label">单价</text>
          <input class="form-input" value="{{editForm.price}}" 
                 data-field="price" bindinput="onEditInput" 
                 placeholder="请输入单价" type="digit"/>
        </view>
        <view class="form-item">
          <text class="form-label">状态</text>
          <picker bindchange="onEditStatusChange" value="{{editForm.status}}" range="{{['pending', 'accepted', 'completed', 'cancelled']}}">
            <view class="picker-value">{{editForm.status}}</view>
          </picker>
        </view>
        <view class="form-item">
          <text class="form-label">交货日期</text>
          <picker mode="date" value="{{editForm.receiveDate}}" bindchange="onEditDateChange">
            <view class="picker-value">{{editForm.receiveDate || '请选择'}}</view>
          </picker>
        </view>
        <view class="form-item">
          <text class="form-label">备注</text>
          <textarea class="form-textarea" value="{{editForm.remark}}" 
                    data-field="remark" bindinput="onEditInput" 
                    placeholder="请输入备注" maxlength="500"/>
        </view>
      </view>
      <view class="modal-footer">
        <button class="btn-cancel" bindtap="hideEditModal">取消</button>
        <button class="btn-confirm" type="primary" bindtap="onSaveEdit">保存</button>
      </view>
    </view>
  </view>
</view>
