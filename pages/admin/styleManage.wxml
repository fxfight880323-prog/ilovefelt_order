<view class="container">
  <!-- 样式列表 -->
  <view class="style-list">
    <view class="style-item" wx:for="{{styleList}}" wx:key="_id">
      <view class="style-info">
        <view class="style-name">{{item.name}}</view>
        <view class="style-meta">
          <text>创建于 {{item.createTime}}</text>
        </view>
      </view>
      <view class="style-actions">
        <view class="action-btn edit" bindtap="showEditModal" data-id="{{item._id}}">
          <text>编辑</text>
        </view>
        <view class="action-btn delete" bindtap="deleteStyle" data-id="{{item._id}}">
          <text>删除</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!loading && styleList.length === 0}}">
    <view class="empty-icon">🎨</view>
    <view class="empty-text">暂无样式</view>
    <view class="empty-desc">点击右下角按钮添加新样式</view>
  </view>
</view>

<!-- 添加/编辑弹窗 -->
<view class="modal" wx:if="{{showAddModal}}" bindtap="closeModal">
  <view class="modal-content" catchtap="preventClose">
    <view class="modal-header">
      <text class="modal-title">{{editingId ? '编辑样式' : '新建样式'}}</text>
      <view class="modal-close" bindtap="closeModal">×</view>
    </view>
    <view class="modal-body">
      <view class="form-item">
        <text class="form-label required">样式名称</text>
        <input 
          class="form-input" 
          placeholder="请输入样式名称"
          value="{{form.name}}"
          bindinput="onNameInput"
          focus="{{showAddModal}}"
        />
      </view>
    </view>
    <view class="modal-footer">
      <view class="btn btn-default" bindtap="closeModal">取消</view>
      <view class="btn btn-primary" bindtap="saveStyle">保存</view>
    </view>
  </view>
</view>

<!-- 添加按钮 -->
<view class="fab" bindtap="showAddModal">+</view>
