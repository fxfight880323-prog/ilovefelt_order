<view class="container">
  <!-- 头部 -->
  <view class="header">
    <view class="back-btn" bindtap="onBack">← 返回</view>
    <view class="title">派单人统计</view>
    <view class="refresh-btn" bindtap="onRefresh">刷新</view>
  </view>

  <!-- 统计概览 -->
  <view class="overview-card">
    <view class="overview-title">📊 统计概览</view>
    <view class="overview-item">
      <text class="overview-label">派单人总数</text>
      <text class="overview-value">{{total}} 人</text>
    </view>
  </view>

  <!-- 排序栏 -->
  <view class="sort-bar">
    <view class="sort-title">排序方式:</view>
    <view class="sort-options">
      <view class="sort-option {{sortBy === 'totalAmount' ? 'active' : ''}}" 
            bindtap="onSortChange" data-field="totalAmount">
        金额 {{sortBy === 'totalAmount' ? (sortOrder === 'desc' ? '↓' : '↑') : ''}}
      </view>
      <view class="sort-option {{sortBy === 'totalOrders' ? 'active' : ''}}" 
            bindtap="onSortChange" data-field="totalOrders">
        订单数 {{sortBy === 'totalOrders' ? (sortOrder === 'desc' ? '↓' : '↑') : ''}}
      </view>
      <view class="sort-option {{sortBy === 'completedOrders' ? 'active' : ''}}" 
            bindtap="onSortChange" data-field="completedOrders">
        完成数 {{sortBy === 'completedOrders' ? (sortOrder === 'desc' ? '↓' : '↑') : ''}}
      </view>
    </view>
  </view>

  <!-- 列表 -->
  <view class="list-container">
    <view wx:if="{{list.length === 0 && !isLoading}}" class="empty-state">
      <text class="empty-icon">📦</text>
      <text class="empty-text">暂无派单人数据</text>
    </view>

    <view class="stats-list">
      <view wx:for="{{list}}" wx:key="_id" class="stats-item" bindtap="viewDetail" data-id="{{item._id}}" data-name="{{item.name}}">
        <view class="item-header">
          <view class="item-info">
            <text class="item-name">{{item.name}}</text>
            <text class="item-phone">{{item.phone}}</text>
          </view>
          <view class="item-status {{item.status}}">{{item.status === 'active' ? '正常' : '禁用'}}</view>
        </view>

        <view class="item-stats">
          <view class="stat-row">
            <view class="stat-box highlight">
              <view class="stat-value money">¥{{item.stats.totalAmount}}</view>
              <view class="stat-label">已完成金额</view>
            </view>
            <view class="stat-box">
              <view class="stat-value">¥{{item.stats.estimatedAmount}}</view>
              <view class="stat-label">预估金额</view>
            </view>
          </view>

          <view class="stat-row">
            <view class="stat-box">
              <view class="stat-value">{{item.stats.totalOrders}}</view>
              <view class="stat-label">总订单</view>
            </view>
            <view class="stat-box">
              <view class="stat-value success">{{item.stats.completedOrders}}</view>
              <view class="stat-label">已完成</view>
            </view>
            <view class="stat-box">
              <view class="stat-value warning">{{item.stats.pendingOrders}}</view>
              <view class="stat-label">待接单</view>
            </view>
            <view class="stat-box">
              <view class="stat-value info">{{item.stats.acceptedOrders}}</view>
              <view class="stat-label">进行中</view>
            </view>
            <view class="stat-box">
              <view class="stat-value grey">{{item.stats.cancelledOrders}}</view>
              <view class="stat-label">已取消</view>
            </view>
          </view>
        </view>

        <view class="item-footer">
          <text class="view-detail">点击查看详情 →</text>
        </view>
      </view>
    </view>

    <!-- 加载更多 -->
    <view wx:if="{{hasMore}}" class="load-more" bindtap="loadMore">
      <text wx:if="{{!isLoading}}">点击加载更多</text>
      <text wx:else>加载中...</text>
    </view>
    <view wx:else class="no-more">没有更多了</view>
  </view>
</view>
