.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

/* 头部 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  background: #07c160;
  color: #fff;
}

.back-btn {
  font-size: 28rpx;
  padding: 10rpx 20rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
}

.refresh-btn {
  font-size: 28rpx;
  padding: 10rpx 20rpx;
}

/* 统计卡片 */
.stats-card {
  background: #fff;
  margin: 20rpx;
  padding: 30rpx;
  border-radius: 16rpx;
  display: flex;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.stats-item {
  text-align: center;
}

.stats-number {
  font-size: 56rpx;
  font-weight: bold;
  color: #07c160;
}

.stats-label {
  font-size: 26rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 筛选栏 */
.filter-bar {
  background: #fff;
  margin: 0 20rpx 20rpx;
  padding: 20rpx;
  border-radius: 16rpx;
}

.filter-tabs {
  display: flex;
  gap: 20rpx;
}

.filter-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: #666;
  background: #f5f5f5;
  border-radius: 8rpx;
}

.filter-tab.active {
  background: #07c160;
  color: #fff;
}

/* 搜索栏 */
.search-bar {
  display: flex;
  gap: 20rpx;
  padding: 0 20rpx 20rpx;
}

.search-input {
  flex: 1;
  height: 80rpx;
  background: #fff;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
}

.search-btn {
  width: 120rpx;
  height: 80rpx;
  background: #07c160;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  font-size: 28rpx;
}

/* 列表 */
.list-container {
  padding: 0 20rpx;
}

.empty-state {
  text-align: center;
  padding: 100rpx 40rpx;
  background: #fff;
  border-radius: 16rpx;
}

.empty-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 20rpx;
}

.empty-text {
  color: #999;
  font-size: 28rpx;
}

.craftsman-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.craftsman-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.item-main {
  flex: 1;
}

.item-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

.item-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.item-status {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.item-status.active {
  background: #e6f7ed;
  color: #07c160;
}

.item-status.pending {
  background: #fff5f0;
  color: #ff6b6b;
}

.item-status.disabled {
  background: #f5f5f5;
  color: #999;
}

.item-phone {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.item-remark {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.item-time {
  font-size: 22rpx;
  color: #bbb;
}

.item-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.btn-edit {
  background: #07c160;
  color: #fff;
  margin: 0;
}

.btn-delete {
  background: #fff;
  color: #ff6b6b;
  border: 1rpx solid #ff6b6b;
  margin: 0;
}

/* 加载更多 */
.load-more, .no-more {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 26rpx;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background: #fff;
  border-radius: 16rpx;
  width: 80%;
  max-width: 600rpx;
  max-height: 80vh;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
}

.modal-close {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
}

.modal-body {
  padding: 30rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  height: 160rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.picker-value {
  height: 80rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  line-height: 80rpx;
}

.modal-footer {
  display: flex;
  padding: 30rpx;
  gap: 20rpx;
  border-top: 1rpx solid #eee;
}

.btn-cancel {
  flex: 1;
  background: #f5f5f5;
  color: #666;
}

.btn-confirm {
  flex: 1;
}
