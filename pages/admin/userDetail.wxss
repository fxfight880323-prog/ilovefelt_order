.container {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 120rpx;
}

/* 加载状态 */
.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 100rpx;
}

.loading-text {
  color: #999;
  font-size: 28rpx;
}

/* 用户卡片 */
.user-card {
  background: linear-gradient(135deg, #1890ff 0%, #36cfc9 100%);
  border-radius: 20rpx;
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 20rpx;
  color: #fff;
}

.user-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  margin-bottom: 20rpx;
}

.user-avatar-placeholder {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.user-name {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
  display: flex;
  align-items: center;
}

.user-code {
  font-size: 28rpx;
  opacity: 0.9;
  margin-left: 12rpx;
}

.user-role {
  display: flex;
  gap: 20rpx;
}

.role-tag {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  background: rgba(255, 255, 255, 0.2);
}

.role-tag.craftsman {
  background: #52c41a;
}

.role-tag.dispatcher {
  background: #faad14;
}

.status-tag {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.status-tag.active {
  background: #52c41a;
}

.status-tag.pending {
  background: #faad14;
}

.status-tag.disabled {
  background: #999;
}

/* 标签栏 */
.tab-bar {
  display: flex;
  background: #fff;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 30rpx 0;
  font-size: 30rpx;
  color: #666;
  position: relative;
}

.tab-item.active {
  color: #1890ff;
  font-weight: bold;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background: #1890ff;
  border-radius: 2rpx;
}

/* 信息卡片 */
.info-section {
  margin-bottom: 20rpx;
}

.info-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.info-list {
  padding: 10rpx 0;
}

.info-row {
  display: flex;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  width: 200rpx;
  color: #666;
  font-size: 30rpx;
}

.info-value {
  flex: 1;
  color: #333;
  font-size: 30rpx;
  font-weight: 500;
}

.star {
  color: #ddd;
  font-size: 28rpx;
  margin-right: 4rpx;
}

.star.active {
  color: #ffd700;
}

.performance {
  font-weight: bold;
}

.performance.good {
  color: #52c41a;
}

.performance.normal {
  color: #faad14;
}

.performance.bad {
  color: #ff4d4f;
}

/* 统计网格 */
.stats-grid {
  display: flex;
  justify-content: space-around;
  padding: 20rpx 0;
}

.stat-item {
  text-align: center;
}

.stat-number {
  font-size: 48rpx;
  font-weight: bold;
  color: #1890ff;
  display: block;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 26rpx;
  color: #666;
}

/* 工作记录 */
.works-section {
  margin-bottom: 20rpx;
}

.work-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.work-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  display: flex;
  gap: 20rpx;
}

.work-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  object-fit: cover;
}

.work-content {
  flex: 1;
}

.work-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.work-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.work-status {
  font-size: 24rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.work-status.completed {
  background: #f6ffed;
  color: #52c41a;
}

.work-status.rework {
  background: #fff1f0;
  color: #ff4d4f;
}

.work-status.inventory {
  background: #fffbe6;
  color: #faad14;
}

.work-info {
  display: flex;
  gap: 30rpx;
  margin-bottom: 8rpx;
}

.work-cost {
  font-size: 26rpx;
  color: #ff4d4f;
}

.work-settlement {
  font-size: 26rpx;
  color: #52c41a;
}

.work-date {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.work-remarks {
  font-size: 24rpx;
  color: #666;
  background: #f5f5f5;
  padding: 12rpx;
  border-radius: 8rpx;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 100rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* 操作区域 */
.action-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 40rpx 40rpx;
  background: #fff;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.btn-primary {
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  color: #fff;
}
