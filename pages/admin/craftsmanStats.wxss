.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

/* 头部 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  background: #07c160;
  color: #fff;
}

.back-btn {
  font-size: 28rpx;
  padding: 10rpx 20rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
}

.refresh-btn {
  font-size: 28rpx;
  padding: 10rpx 20rpx;
}

/* 概览卡片 */
.overview-card {
  background: #fff;
  margin: 20rpx;
  padding: 30rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.overview-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.overview-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-top: 1rpx solid #f0f0f0;
}

.overview-label {
  font-size: 28rpx;
  color: #666;
}

.overview-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #07c160;
}

/* 排序栏 */
.sort-bar {
  background: #fff;
  margin: 0 20rpx 20rpx;
  padding: 20rpx;
  border-radius: 16rpx;
}

.sort-title {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.sort-options {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.sort-option {
  padding: 12rpx 24rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #666;
}

.sort-option.active {
  background: #07c160;
  color: #fff;
}

/* 列表 */
.list-container {
  padding: 0 20rpx;
}

.empty-state {
  text-align: center;
  padding: 100rpx 40rpx;
  background: #fff;
  border-radius: 16rpx;
}

.empty-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 20rpx;
}

.empty-text {
  color: #999;
  font-size: 28rpx;
}

.stats-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.stats-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.item-info {
  flex: 1;
}

.item-name-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.item-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.item-level {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  background: #fff3e0;
  color: #ff9500;
  border-radius: 8rpx;
}

.item-phone {
  font-size: 26rpx;
  color: #999;
}

.item-status {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.item-status.active {
  background: #e6f7ed;
  color: #07c160;
}

.item-status.disabled {
  background: #f5f5f5;
  color: #999;
}

/* 评分区域 */
.rating-section {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #f9f9f9;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.rating-display {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.rating-score {
  font-size: 48rpx;
  font-weight: bold;
  color: #ff9500;
}

.rating-stars {
  display: flex;
  gap: 4rpx;
}

.star {
  font-size: 32rpx;
  color: #ddd;
}

.star.active {
  color: #ff9500;
}

.rating-count {
  font-size: 24rpx;
  color: #999;
}

.btn-edit-rating {
  background: #07c160;
  color: #fff;
  margin: 0;
}

/* 统计区域 */
.item-stats {
  margin-bottom: 20rpx;
}

.stat-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.stat-row:last-child {
  margin-bottom: 0;
}

.stat-box {
  flex: 1;
  background: #f9f9f9;
  border-radius: 12rpx;
  padding: 20rpx;
  text-align: center;
}

.stat-box.highlight {
  flex: 1.5;
  background: #fff5f0;
}

.stat-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.stat-value.money {
  color: #ff6b6b;
  font-size: 36rpx;
}

.stat-value.success {
  color: #07c160;
}

.stat-value.info {
  color: #2f7cf7;
}

.stat-label {
  font-size: 22rpx;
  color: #999;
}

/* 管理员备注 */
.admin-comment {
  background: #f0f9f4;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-top: 20rpx;
}

.comment-label {
  font-size: 24rpx;
  color: #07c160;
  font-weight: bold;
  display: block;
  margin-bottom: 8rpx;
}

.comment-text {
  font-size: 26rpx;
  color: #666;
}

/* 加载更多 */
.load-more, .no-more {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 26rpx;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background: #fff;
  border-radius: 16rpx;
  width: 80%;
  max-width: 600rpx;
  max-height: 80vh;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
}

.modal-close {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
}

.modal-body {
  padding: 30rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  height: 160rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.rating-preview {
  margin-top: 16rpx;
  text-align: center;
}

.modal-footer {
  display: flex;
  padding: 30rpx;
  gap: 20rpx;
  border-top: 1rpx solid #eee;
}

.btn-cancel {
  flex: 1;
  background: #f5f5f5;
  color: #666;
}

.btn-confirm {
  flex: 1;
}
