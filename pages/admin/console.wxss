.container {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

/* 头部 */
.header {
  background: linear-gradient(135deg, #07c160 0%, #059e4c 100%);
  padding: 40rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  text-align: center;
}

.admin-badge {
  display: inline-block;
  background: rgba(255,255,255,0.2);
  color: #fff;
  padding: 8rpx 24rpx;
  border-radius: 30rpx;
  font-size: 28rpx;
  margin-bottom: 16rpx;
}

.admin-phone {
  color: #fff;
  font-size: 36rpx;
  font-weight: bold;
}

/* 统计卡片 */
.stats-section {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  color: #333;
}

.stats-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.stat-card {
  flex: 1;
  min-width: 140rpx;
  background: #fff;
  padding: 30rpx 20rpx;
  border-radius: 12rpx;
  text-align: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.stat-card.highlight {
  background: #fff5f0;
  border: 2rpx solid #ff6b6b;
}

.stat-number {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
}

.stat-card.highlight .stat-number {
  color: #ff6b6b;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 标签栏 */
.tab-bar {
  display: flex;
  background: #fff;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 30rpx;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab-item.active {
  color: #07c160;
  font-weight: bold;
  background: #f0f9f4;
}

.badge {
  display: inline-block;
  background: #ff6b6b;
  color: #fff;
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  border-radius: 20rpx;
  margin-left: 8rpx;
}

/* 待审批列表 */
.pending-section {
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.refresh-btn {
  color: #07c160;
  font-size: 26rpx;
}

.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 20rpx;
}

.empty-text {
  color: #999;
  font-size: 28rpx;
}

.pending-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.pending-item {
  background: #f9f9f9;
  border-radius: 12rpx;
  padding: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.user-info {
  flex: 1;
}

.user-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.user-phone {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.apply-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.role-tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}

.role-tag.craftsman {
  background: #e6f7ed;
  color: #07c160;
}

.role-tag.dispatcher {
  background: #e6f0ff;
  color: #2f7cf7;
}

.apply-time {
  font-size: 22rpx;
  color: #999;
}

.action-btns {
  display: flex;
  gap: 16rpx;
}

.btn-reject {
  background: #fff;
  color: #ff6b6b;
  border: 1rpx solid #ff6b6b;
}

.btn-approve {
  background: #07c160;
  color: #fff;
}

/* 统计详情 */
.stats-detail {
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
}

.stat-row {
  display: flex;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.stat-row:last-child {
  border-bottom: none;
}

.stat-label {
  font-size: 28rpx;
  color: #666;
}

.stat-value {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
}

.stat-value.highlight {
  color: #ff6b6b;
}

/* 退出按钮 */
.logout-section {
  margin-top: 40rpx;
  padding: 0 20rpx;
}

.logout-btn {
  background: #fff;
  color: #ff6b6b;
  border: 1rpx solid #ff6b6b;
}

.loading {
  text-align: center;
  padding: 100rpx;
  color: #999;
}
