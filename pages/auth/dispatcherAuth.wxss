.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

.auth-header {
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  padding: 60rpx 40rpx;
  text-align: center;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  display: block;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

.tip-bar {
  display: flex;
  align-items: center;
  background: #e6f7ff;
  padding: 20rpx 30rpx;
  margin: 20rpx 30rpx 0;
  border-radius: 12rpx;
  border: 1rpx solid #91d5ff;
}

.tip-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.tip-text {
  flex: 1;
  font-size: 26rpx;
  color: #096dd9;
}

.form-container {
  padding: 30rpx;
}

.form-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #f0f0f0;
  display: flex;
  align-items: center;
}

.section-title .icon {
  margin-right: 12rpx;
}

.form-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.form-item:last-child {
  border-bottom: none;
}

.label {
  width: 180rpx;
  font-size: 30rpx;
  color: #333;
  flex-shrink: 0;
}

.label.required::before {
  content: '* ';
  color: #ff4d4f;
}

.input {
  flex: 1;
  font-size: 30rpx;
  color: #333;
  height: 60rpx;
}

.input::placeholder {
  color: #999;
}

/* 验证码 */
.verify-code-wrapper {
  flex: 1;
  display: flex;
  align-items: center;
}

.verify-input {
  flex: 1;
  margin-right: 20rpx;
}

.send-code-btn {
  width: 200rpx;
  height: 64rpx;
  line-height: 64rpx;
  font-size: 26rpx;
  color: #fff;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  border-radius: 32rpx;
  padding: 0;
  margin: 0;
}

.send-code-btn.disabled {
  background: #ccc;
}

.send-code-btn::after {
  border: none;
}

.feature-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.feature-list {
  margin-top: 20rpx;
}

.feature-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.feature-item:last-child {
  border-bottom: none;
}

.feature-icon {
  font-size: 48rpx;
  margin-right: 24rpx;
}

.feature-info {
  flex: 1;
}

.feature-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.feature-desc {
  font-size: 26rpx;
  color: #999;
}

.protocol-section {
  margin: 30rpx 0;
}

.protocol-label {
  display: flex;
  align-items: center;
  font-size: 26rpx;
}

.protocol-text {
  color: #666;
  margin-left: 8rpx;
}

.protocol-link {
  color: #1890ff;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 48rpx;
  margin-top: 40rpx;
}

.submit-btn.loading {
  opacity: 0.7;
}

.submit-btn::after {
  border: none;
}

.tips {
  text-align: center;
  margin-top: 30rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #999;
}

.back-link {
  text-align: center;
  margin-top: 30rpx;
}

.back-link text {
  font-size: 28rpx;
  color: #999;
}

/* 联系管理员 */
.contact-section {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 30rpx 0;
  padding: 24rpx 30rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
}

.contact-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.contact-text {
  font-size: 26rpx;
  color: #667eea;
  flex: 1;
}

.contact-arrow {
  font-size: 28rpx;
  color: #999;
}
