<view class="container">
  <!-- 自动登录中提示 -->
  <view class="auto-login-container" wx:if="{{isAutoLogin}}">
    <view class="loading-spinner"></view>
    <text class="auto-login-text">正在登录...</text>
    <text class="auto-login-subtext">检测到您已注册，自动跳转中</text>
  </view>

  <!-- 角色选择 -->
  <view class="role-select-container" wx:if="{{!isAutoLogin && !loading}}">
    <view class="header">
      <image class="logo" src="/images/home.png" mode="aspectFit"/>
      <text class="title">手工艺派单系统</text>
      <text class="subtitle">请选择您的角色</text>
    </view>

    <view class="role-cards">
      <!-- 手艺人卡片 -->
      <view class="role-card craftsman" bindtap="selectCraftsman">
        <view class="role-icon">
          <text class="iconfont">🎨</text>
        </view>
        <view class="role-info">
          <text class="role-name">我是手艺人</text>
          <text class="role-desc">接单制作手工艺品</text>
          <view class="role-features">
            <text class="feature">浏览订单</text>
            <text class="feature">抢单接单</text>
            <text class="feature">查看收入</text>
          </view>
        </view>
        <text class="arrow">→</text>
      </view>

      <!-- 派单人卡片 -->
      <view class="role-card dispatcher" bindtap="selectDispatcher">
        <view class="role-icon">
          <text class="iconfont">📋</text>
        </view>
        <view class="role-info">
          <text class="role-name">我是派单人</text>
          <text class="role-desc">发布订单寻找手艺人</text>
          <view class="role-features">
            <text class="feature">发布订单</text>
            <text class="feature">管理订单</text>
            <text class="feature">查看进度</text>
          </view>
        </view>
        <text class="arrow">→</text>
      </view>
    </view>

    <view class="footer">
      <text class="help-link" bindtap="viewHelp">角色说明</text>
    </view>
  </view>

  <!-- 加载中 -->
  <view class="loading-container" wx:if="{{loading && !isAutoLogin}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>
</view>
