.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 自动登录中 */
.auto-login-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.auto-login-text {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  margin-top: 40rpx;
  margin-bottom: 20rpx;
}

.auto-login-subtext {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 加载中 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.loading-text {
  font-size: 32rpx;
  color: #fff;
  margin-top: 30rpx;
}

/* 加载动画 */
.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: #fff;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

/* 角色选择 */
.role-select-container {
  width: 100%;
}

.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
  margin-top: 40rpx;
}

.logo {
  width: 120rpx;
  height: 120rpx;
  border-radius: 24rpx;
  background: #fff;
  padding: 20rpx;
  margin-bottom: 24rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.role-cards {
  width: 100%;
}

.role-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.1);
  transition: transform 0.3s;
}

.role-card:active {
  transform: scale(0.98);
}

.role-card.craftsman {
  border-left: 8rpx solid #52c41a;
}

.role-card.dispatcher {
  border-left: 8rpx solid #1890ff;
}

.role-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-right: 30rpx;
  flex-shrink: 0;
}

.craftsman .role-icon {
  background: #f6ffed;
}

.dispatcher .role-icon {
  background: #e6f7ff;
}

.role-info {
  flex: 1;
}

.role-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.role-desc {
  font-size: 26rpx;
  color: #999;
  display: block;
  margin-bottom: 16rpx;
}

.role-features {
  display: flex;
  flex-wrap: wrap;
}

.feature {
  font-size: 22rpx;
  color: #666;
  background: #f5f5f5;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  margin-right: 12rpx;
  margin-bottom: 8rpx;
}

.arrow {
  font-size: 40rpx;
  color: #ccc;
}

.footer {
  margin-top: 40rpx;
  text-align: center;
}

.help-link {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  text-decoration: underline;
}
