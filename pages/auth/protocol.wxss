.container {
  min-height: 100vh;
  background: #fff;
  padding: 40rpx;
}

.protocol-content {
  line-height: 1.8;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 40rpx;
}

.section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.section-text {
  font-size: 28rpx;
  color: #666;
  text-align: justify;
}

.footer {
  margin-top: 60rpx;
  text-align: center;
  font-size: 24rpx;
  color: #999;
}
