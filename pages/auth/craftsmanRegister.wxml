<view class="container">
  <view class="register-header">
    <text class="title">手艺人注册</text>
    <text class="subtitle">填写个人信息，开启接单之旅</text>
  </view>

  <view class="form-container">
    <!-- 基本信息 -->
    <view class="form-section">
      <view class="section-title">基本信息</view>
      
      <view class="form-item">
        <text class="label required">姓名</text>
        <input 
          class="input" 
          placeholder="请输入真实姓名" 
          value="{{form.name}}"
          data-field="name"
          bindinput="onInput"
        />
      </view>

      <view class="form-item">
        <text class="label required">手机号</text>
        <input 
          class="input" 
          placeholder="请输入手机号" 
          type="number"
          maxlength="11"
          value="{{form.phone}}"
          data-field="phone"
          bindinput="onInput"
        />
      </view>

      <!-- 验证码 -->
      <view class="form-item">
        <text class="label required">验证码</text>
        <view class="verify-code-wrapper">
          <input 
            class="input verify-input" 
            placeholder="请输入验证码" 
            type="number"
            maxlength="6"
            value="{{form.verifyCode}}"
            data-field="verifyCode"
            bindinput="onInput"
          />
          <button 
            class="send-code-btn {{canSendCode ? '' : 'disabled'}}" 
            bindtap="sendVerifyCode"
            disabled="{{!canSendCode}}"
          >
            {{countdown > 0 ? countdown + 's' : '获取验证码'}}
          </button>
        </view>
      </view>

      <view class="form-item">
        <text class="label">微信号</text>
        <input 
          class="input" 
          placeholder="请输入微信号（选填）" 
          value="{{form.wechatId}}"
          data-field="wechatId"
          bindinput="onInput"
        />
      </view>

      <view class="form-item">
        <text class="label required">登录密码</text>
        <input 
          class="input" 
          placeholder="请设置6-20位密码" 
          type="text"
          password="{{true}}"
          maxlength="20"
          value="{{form.password}}"
          data-field="password"
          bindinput="onInput"
        />
      </view>

      <view class="form-item">
        <text class="label required">确认密码</text>
        <input 
          class="input" 
          placeholder="请再次输入密码" 
          type="text"
          password="{{true}}"
          maxlength="20"
          value="{{form.confirmPassword}}"
          data-field="confirmPassword"
          bindinput="onInput"
        />
      </view>
    </view>

    <!-- 专业信息 -->
    <view class="form-section">
      <view class="section-title">专业信息</view>
      
      <view class="form-item">
        <text class="label required">擅长工艺</text>
        <picker mode="selector" range="{{specialties}}" bindchange="onSpecialtyChange">
          <view class="picker {{specialtyIndex === -1 ? 'placeholder' : ''}}">
            {{specialtyIndex === -1 ? '请选择擅长工艺' : specialties[specialtyIndex]}}
          </view>
        </picker>
      </view>

      <view class="form-item">
        <text class="label required">从业经验</text>
        <picker mode="selector" range="{{experiences}}" bindchange="onExperienceChange">
          <view class="picker {{experienceIndex === -1 ? 'placeholder' : ''}}">
            {{experienceIndex === -1 ? '请选择从业经验' : experiences[experienceIndex]}}
          </view>
        </picker>
      </view>

      <view class="form-item">
        <text class="label required">所在地区</text>
        <input 
          class="input" 
          placeholder="请输入所在地区" 
          value="{{form.address}}"
          data-field="address"
          bindinput="onInput"
        />
      </view>
    </view>

    <!-- 身份信息 -->
    <view class="form-section">
      <view class="section-title">身份信息（选填）</view>
      
      <view class="form-item">
        <text class="label">身份证号</text>
        <input 
          class="input" 
          placeholder="用于实名认证" 
          type="idcard"
          maxlength="18"
          value="{{form.idCard}}"
          data-field="idCard"
          bindinput="onInput"
        />
      </view>
    </view>

    <!-- 协议 -->
    <view class="protocol-section">
      <checkbox-group bindchange="onAgreeChange">
        <label class="protocol-label">
          <checkbox value="agree" checked="{{agreeProtocol}}"/>
          <text class="protocol-text">我已阅读并同意</text>
          <text class="protocol-link" bindtap="viewProtocol">《手艺人服务协议》</text>
        </label>
      </checkbox-group>
    </view>

    <!-- 提交按钮 -->
    <button 
      class="submit-btn {{loading ? 'loading' : ''}}" 
      bindtap="submitRegister"
      disabled="{{loading}}"
    >
      {{loading ? '提交中...' : '提交注册'}}
    </button>

    <view class="tips">
      <text class="tip-text">提交后需要管理员审核通过</text>
    </view>

    <!-- 联系管理员 -->
    <view class="contact-section" bindtap="goToContactAdmin">
      <text class="contact-icon">📞</text>
      <text class="contact-text">遇到问题？联系管理员：13810062394</text>
      <text class="contact-arrow">></text>
    </view>
  </view>
</view>
