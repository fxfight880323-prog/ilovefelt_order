/* Sùyǎ Artisans - Index Page Styles */

/* Hero Section Override */
.hero-section {
  padding: 48rpx 40rpx 32rpx;
  margin: -20rpx -20rpx 0;
}

/* Function Items */
.func-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 10rpx;
  border-radius: 16rpx;
  transition: background var(--duration-fast);
}

.func-item:active {
  background: var(--surface-container);
}

.func-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  margin-bottom: 16rpx;
}

.func-text {
  font-size: 24rpx;
  color: var(--on-surface);
  font-weight: 500;
}

/* Notice Row */
.notice-row {
  display: flex;
  align-items: flex-start;
  padding: 16rpx 0;
}

/* Stats Grid Enhancement */
.stat-highlight {
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-container) 100%);
  color: var(--on-primary);
}

/* User Card Specific */
.user-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 12rpx;
}

.user-location {
  font-size: 24rpx;
  color: var(--on-surface-variant);
  display: flex;
  align-items: center;
  gap: 6rpx;
}

/* Multi-role badge */
.role-badge {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 16rpx;
  background: var(--tertiary-fixed);
  color: var(--on-tertiary-fixed);
  border-radius: 9999rpx;
  font-size: 22rpx;
  font-weight: 500;
}
