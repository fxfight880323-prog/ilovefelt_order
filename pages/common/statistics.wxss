/* 页面头部 */
.page-header {
  background: linear-gradient(135deg, #1890ff 0%, #36cfc9 100%);
  padding: 40rpx 30rpx;
  color: #fff;
  margin: -20rpx -20rpx 20rpx -20rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: 600;
  margin-bottom: 10rpx;
}

.page-subtitle {
  font-size: 26rpx;
  opacity: 0.8;
}

/* 角色切换标签 */
.role-tabs {
  display: flex;
  background: #fff;
  border-radius: 12rpx;
  padding: 10rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 10rpx;
  font-size: 28rpx;
  color: #666;
  border-radius: 8rpx;
  transition: all 0.3s;
}

.tab-item.active {
  background: #1890ff;
  color: #fff;
}

/* 统计网格 */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.stat-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx 10rpx;
  text-align: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.stat-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin: 0 auto 16rpx;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 22rpx;
  color: #999;
}

/* 图表卡片 */
.chart-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.picker-btn {
  font-size: 26rpx;
  color: #1890ff;
  padding: 10rpx 20rpx;
  background: #e6f7ff;
  border-radius: 8rpx;
}

.chart-container {
  height: 400rpx;
}

.chart-canvas {
  width: 100%;
  height: 100%;
}

/* 排行榜卡片 */
.rank-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.rank-list {
  margin-top: 20rpx;
}

.rank-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.rank-item:last-child {
  border-bottom: none;
}

.rank-number {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #f5f5f5;
  color: #999;
  font-size: 26rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.rank-number.top {
  background: linear-gradient(135deg, #ffd700, #ffaa00);
  color: #fff;
}

.rank-info {
  flex: 1;
}

.rank-name {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.rank-meta {
  display: flex;
  gap: 20rpx;
  font-size: 24rpx;
  color: #999;
}

.rank-score {
  color: #faad14;
}

.rank-count {
  color: #666;
}

.rank-amount {
  font-size: 30rpx;
  color: #f5222d;
  font-weight: 600;
}

.rank-amount-primary {
  font-size: 32rpx;
  color: #e53935;
  font-weight: 700;
}

.card-subtitle {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 评分卡片 */
.rating-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.rating-overview {
  text-align: center;
  padding: 40rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  margin-bottom: 30rpx;
}

.rating-score {
  font-size: 72rpx;
  font-weight: 600;
  color: #faad14;
  margin-bottom: 16rpx;
}

.rating-stars {
  margin-bottom: 16rpx;
}

.rating-stars .star {
  font-size: 40rpx;
  color: #ddd;
}

.rating-stars .star.active {
  color: #faad14;
}

.rating-count {
  font-size: 26rpx;
  color: #999;
}

.rating-list {
  margin-top: 20rpx;
}

.rating-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.rating-item:last-child {
  border-bottom: none;
}

.rating-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.rating-stars-small {
  display: flex;
}

.star-small {
  font-size: 24rpx;
  color: #faad14;
}

.rating-time {
  font-size: 24rpx;
  color: #999;
}

.rating-comment {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

/* 响应式调整 */
@media (max-width: 375px) {
  .stats-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}
