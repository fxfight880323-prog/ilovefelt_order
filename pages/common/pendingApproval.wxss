.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 60rpx 40rpx;
  text-align: center;
}

/* 状态图标 */
.status-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.status-icon.pending {
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.1); }
}

.status-icon.success {
  color: #52c41a;
}

.status-icon.rejected {
  color: #ff4d4f;
}

/* 状态标题 */
.status-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

/* 状态描述 */
.status-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 40rpx;
}

.highlight {
  color: #667eea;
  font-weight: bold;
}

.rejected-text {
  color: #ff4d4f;
}

/* 信息卡片 */
.info-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 40rpx;
  text-align: left;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #666;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.status-pending {
  color: #faad14;
}

.status-active {
  color: #52c41a;
}

.status-rejected {
  color: #ff4d4f;
}

/* 拒绝原因 */
.reject-reason {
  margin-top: 20rpx;
  padding: 20rpx;
  background: #fff1f0;
  border-radius: 12rpx;
}

.reason-label {
  display: block;
  font-size: 26rpx;
  color: #ff4d4f;
  margin-bottom: 10rpx;
}

.reason-content {
  display: block;
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
}

/* 提示 */
.tips {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 30rpx;
  background: #e6f7ff;
  border-radius: 12rpx;
  margin-bottom: 40rpx;
}

.tips-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.tips-text {
  font-size: 26rpx;
  color: #1890ff;
  flex: 1;
  text-align: left;
}

.success-tips {
  background: #f6ffed;
}

.success-tips .tips-text {
  color: #52c41a;
}

.warning-tips {
  background: #fffbe6;
}

.warning-tips .tips-text {
  color: #faad14;
}

/* 操作按钮 */
.action-btn {
  background: #667eea;
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  padding: 28rpx 0;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.action-btn.primary {
  background: #52c41a;
}

.action-btn.secondary {
  background: #f5f5f5;
  color: #666;
}

.action-group {
  display: flex;
  gap: 20rpx;
}

.action-group .action-btn {
  flex: 1;
}

/* 加载中 */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f0f0f0;
  border-top-color: #667eea;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}
