# 云函数环境变量配置
# 复制此文件为 .env 并在微信开发者工具的云函数配置中设置

# 小程序 AppID
APPID=wx19302c485b354857

# 小程序 AppSecret（不要在代码中硬编码！）
# 在微信公众平台获取，用于发送订阅消息等接口调用
APPSECRET=e50eb591ac000da51efe3ae34b528c48

# 说明：
# 1. AppSecret 是敏感信息，不要提交到代码仓库
# 2. 在微信开发者工具中设置云函数环境变量：
#    云开发 → 云函数 → 选择函数 → 版本与配置 → 环境变量
# 3. 在代码中使用：process.env.APPSECRET
